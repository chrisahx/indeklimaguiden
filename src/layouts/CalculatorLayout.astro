---
import BaseLayout from './BaseLayout.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import GoogleAd from '../components/GoogleAd.astro';
import { ADSENSE_SLOTS } from '../lib/adsense';

interface BreadcrumbItem {
  name: string;
  url: string;
}

interface Action {
  label: string;
  href: string;
}

interface Props {
  title: string;
  description: string;
  path: string;
  breadcrumbs: BreadcrumbItem[];
  pill: string;
  h1: string;
  primaryAction?: Action;
  secondaryAction?: Action;
  calculatorPill: string;
  calculatorHeading: string;
  calculatorDescription: string;
}

const {
  title,
  description,
  path,
  breadcrumbs,
  pill,
  h1,
  primaryAction,
  secondaryAction,
  calculatorPill,
  calculatorHeading,
  calculatorDescription,
} = Astro.props;

const sidebarAdSlot = ADSENSE_SLOTS.calculatorSidebar;
const wideAdSlot = ADSENSE_SLOTS.calculatorWide;
const articleAdSlot = ADSENSE_SLOTS.calculatorArticle;
const mobileAdSlotOne = ADSENSE_SLOTS.calculatorMobile1;
const mobileAdSlotTwo = ADSENSE_SLOTS.calculatorMobile2;
const leftRailAdSlot = ADSENSE_SLOTS.calculatorLeftRail;
const rightRailAdSlot = ADSENSE_SLOTS.calculatorRightRail;
const showSidebarAd = import.meta.env.DEV || sidebarAdSlot;
const showWideAd = import.meta.env.DEV || wideAdSlot;
const showArticleAd = import.meta.env.DEV || articleAdSlot;
const showMobileAdOne = import.meta.env.DEV || mobileAdSlotOne;
const showMobileAdTwo = import.meta.env.DEV || mobileAdSlotTwo;
const showLeftRailAd = import.meta.env.DEV || leftRailAdSlot;
const showRightRailAd = import.meta.env.DEV || rightRailAdSlot;
---

<BaseLayout title={title} description={description} path={path}>
  <section class="calculator-hero">
    <div class="container hero-copy">
      <Breadcrumbs items={breadcrumbs} />
      <span class="pill">{pill}</span>
      <h1>{h1}</h1>
      <slot name="hero-intro" />
      {(primaryAction || secondaryAction) && (
        <div class="hero-actions">
          {primaryAction && <a class="button" href={primaryAction.href}>{primaryAction.label}</a>}
          {secondaryAction && <a class="button secondary" href={secondaryAction.href}>{secondaryAction.label}</a>}
        </div>
      )}
      <aside class="surface quick-answer" aria-label="Kort svar">
        <span class="pill">Kort svar</span>
        <slot name="quick-answer" />
      </aside>
    </div>
  </section>

  <section id="beregner" class="section container calculator-section" aria-labelledby="calculator-heading">
    <div class="section-heading">
      <span class="pill">{calculatorPill}</span>
      <h2 id="calculator-heading">{calculatorHeading}</h2>
      <p>{calculatorDescription}</p>
    </div>

    <div class:list={['calculator-layout', showSidebarAd && 'has-sidebar-ad']}>
      <slot name="calculator" />

      {showSidebarAd && (
        <aside class="ad-column" aria-label="Annonce">
          <GoogleAd slotId={sidebarAdSlot} className="sidebar-ad" />
        </aside>
      )}
    </div>
  </section>

  {showWideAd && (
    <aside class="container" aria-label="Annonce">
      <GoogleAd slotId={wideAdSlot} className="wide-ad" />
    </aside>
  )}

  <article class:list={['article-shell', (showLeftRailAd || showRightRailAd) && 'has-rail-ads']}>
    {showLeftRailAd && (
      <aside class="rail-ad left-rail" aria-label="Annonce">
        <GoogleAd slotId={leftRailAdSlot} className="rail-ad-unit" />
      </aside>
    )}

    <div class="article-main">
      <aside class="reading side-panel">
        <slot name="side-panel" />
      </aside>

      <div class="reading article-body content-card">
        <slot name="article-start" />
        {showMobileAdOne && <GoogleAd slotId={mobileAdSlotOne} className="calculator-mobile-ad" />}
        <slot name="article-main" />
        {showMobileAdTwo && <GoogleAd slotId={mobileAdSlotTwo} className="calculator-mobile-ad" />}
        <slot name="article-late" />
        {showArticleAd && <GoogleAd slotId={articleAdSlot} className="article-ad" />}
        <slot name="article-end" />
      </div>
    </div>

    {showRightRailAd && (
      <aside class="rail-ad right-rail" aria-label="Annonce">
        <GoogleAd slotId={rightRailAdSlot} className="rail-ad-unit" />
      </aside>
    )}
  </article>

  <slot name="structured-data" />
</BaseLayout>

<style>
  .calculator-hero { padding: clamp(4rem, 8vw, 7rem) 0 clamp(2.25rem, 5vw, 4rem); }
  .hero-copy { text-align: center; }
  .hero-copy :global(.breadcrumbs) { justify-content: center; }
  .hero-copy h1 { max-width: 1020px; margin: 0.85rem auto 1rem; font-size: clamp(2.65rem, 6vw, 5.35rem); }
  .hero-copy :global(p) { max-width: 860px; margin-inline: auto; color: var(--color-muted); font-size: clamp(1.08rem, 2vw, 1.32rem); }
  .hero-actions { display: flex; flex-wrap: wrap; justify-content: center; gap: 0.75rem; margin-top: 1.4rem; }
  .quick-answer { max-width: 780px; margin: 2rem auto 0; padding: 1.35rem; background: linear-gradient(145deg, rgba(255, 255, 255, 0.96), rgba(220, 251, 255, 0.72)); }
  .quick-answer :global(p) { margin: 1rem 0 0; color: var(--color-primary); font-size: 1.12rem; }
  .section-heading { margin-bottom: 1.5rem; }
  .section-heading h2 { margin-top: 0.8rem; }
  .section-heading p { max-width: 760px; color: var(--color-muted); font-size: 1.1rem; }
  .calculator-layout { display: grid; gap: 1.15rem; align-items: start; }
  .calculator-layout.has-sidebar-ad { grid-template-columns: minmax(0, 1fr) minmax(260px, 0.32fr); }
  .ad-column { position: sticky; top: 104px; }
  :global(.sidebar-ad) { min-height: 420px; }
  :global(.wide-ad) { min-height: 92px; margin-bottom: clamp(2rem, 5vw, 4rem); }
  :global(.article-ad) { min-height: 120px; margin: 2.5rem 0; }
  :global(.calculator-mobile-ad) { display: none; min-height: 120px; margin: 2rem 0; }
  .article-shell { width: min(800px, calc(100% - 40px)); margin-inline: auto; padding-bottom: clamp(3rem, 7vw, 6rem); }
  .article-shell.has-rail-ads { display: grid; grid-template-columns: minmax(140px, 1fr) minmax(0, 800px) minmax(140px, 1fr); gap: clamp(1rem, 3vw, 2rem); width: min(1420px, calc(100% - 40px)); margin-inline: auto; align-items: start; }
  .article-main { grid-column: 2; min-width: 0; }
  .article-shell:not(.has-rail-ads) .reading { width: 100%; margin-inline: 0; }
  .article-shell.has-rail-ads .reading { width: 100%; }
  .rail-ad { position: sticky; top: 104px; min-width: 0; }
  :global(.rail-ad-unit) { min-height: 600px; }
  .left-rail { grid-column: 1; }
  .right-rail { grid-column: 3; }
  .content-card { padding: clamp(1.35rem, 4vw, 2.75rem); background: #fff; border: 1px solid rgba(217, 229, 232, 0.7); border-radius: var(--radius-xl); box-shadow: 0 1px 2px rgba(6, 25, 35, 0.025); }
  .side-panel { margin: 0 0 1.25rem; }
  .side-panel :global(.checklist) { border: 1px solid var(--color-border); border-radius: var(--radius-lg); padding: clamp(1.1rem, 3vw, 1.5rem); background: rgba(255, 255, 255, 0.7); }
  .side-panel :global(.checklist h2) { margin-top: 0; font-size: 1.35rem; }
  .side-panel :global(.checklist ul) { margin: 0; padding-left: 1.25rem; color: var(--color-muted); }
  .side-panel :global(.checklist li + li) { margin-top: 0.55rem; }

  @media (max-width: 920px) {
    .calculator-layout.has-sidebar-ad { grid-template-columns: 1fr; }
    .ad-column { position: static; }
    :global(.sidebar-ad) { min-height: 120px; }
    .article-shell.has-rail-ads { display: block; width: auto; }
    .rail-ad { display: none; }
    :global(.calculator-mobile-ad) { display: block; }
  }
</style>
