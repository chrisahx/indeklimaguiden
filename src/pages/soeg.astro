---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Søg" description="Søg i Indeklima Guidens artikler om aircondition, varmepumper og indeklima." path="/soeg/">
  <section class="section reading">
    <span class="pill">Søg</span>
    <h1>Søg på Indeklima Guiden</h1>
    <p>Find guides, forklaringer og redaktionelle vurderinger.</p>
    <div id="search"></div>
  </section>
  <link href="/pagefind/pagefind-ui.css" rel="stylesheet" />
  <script is:inline src="/pagefind/pagefind-ui.js"></script>
  <script is:inline>
    window.addEventListener('DOMContentLoaded', () => {
      if (!window.PagefindUI) return;
      new window.PagefindUI({ element: '#search', showSubResults: true, translations: { placeholder: 'Søg efter emne' } });
      const params = new URLSearchParams(window.location.search);
      const query = params.get('q');
      if (query) {
        const input = document.querySelector('#search input');
        if (input) {
          input.value = query;
          input.dispatchEvent(new Event('input', { bubbles: true }));
        }
      }
    });
  </script>
</BaseLayout>
