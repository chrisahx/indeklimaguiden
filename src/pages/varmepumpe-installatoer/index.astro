---
export const prerender = false;

import Breadcrumbs from '../../components/Breadcrumbs.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getPrisma } from '../../lib/prisma';
import { slugifyCity } from '../../lib/slugs';

interface CityRow {
  city_name: string;
  company_count: number;
  postal_codes: string[] | null;
}

let cities: Array<{ name: string; slug: string; companyCount: number; postalCodes: string[] }> = [];
let dbError = '';

try {
  const rows = await getPrisma().$queryRaw<CityRow[]>`
    select
      min(trim(company_locations.city)) as city_name,
      count(*)::int as company_count,
      array_remove(array_agg(distinct nullif(trim(company_locations.postal_code), '') order by nullif(trim(company_locations.postal_code), '')), null) as postal_codes
    from company_locations
    join companies on companies.id = company_locations.company_id
    where nullif(trim(company_locations.city), '') is not null
    group by lower(trim(company_locations.city))
    order by city_name asc
  `;
  cities = rows
    .map((row) => ({
      name: row.city_name,
      slug: slugifyCity(row.city_name),
      companyCount: row.company_count,
      postalCodes: row.postal_codes ?? [],
    }))
    .filter((city) => city.slug);
} catch (error) {
  dbError = error instanceof Error ? error.message : 'Kunne ikke hente byer fra databasen.';
}

const totalCompanies = cities.reduce((sum, city) => sum + city.companyCount, 0);
const citySearchData = cities.map((city) => ({
  name: city.name,
  slug: city.slug,
  companyCount: city.companyCount,
  postalCodes: city.postalCodes,
}));
const citySearchJson = JSON.stringify(citySearchData).replace(/</g, '\\u003c');
---

<BaseLayout
  title="Varmepumpe installatører i Danmark"
  description="Find lokale varmepumpe installatører i Danmark. Vælg en by og se virksomheder, kontaktoplysninger og offentligt indsamlede anmeldelsesdata."
  path="/varmepumpe-installatoer/"
>
  <section class="section container directory-hero">
    <div>
      <Breadcrumbs items={[{ name: 'Forside', url: '/' }, { name: 'Varmepumpe installatører', url: '/varmepumpe-installatoer/' }]} />
      <span class="pill">Installatørregister</span>
      <h1>Find varmepumpe installatører nær dig</h1>
      <p>
        Vælg din by og få et lokalt overblik over virksomheder, der arbejder med varmepumper. Oversigten bygger på offentligt tilgængelige virksomhedsdata og anmeldelseskilder.
      </p>
    </div>
    <aside class="surface stats-card" aria-label="Status for installatørregisteret">
      <strong>{totalCompanies}</strong>
      <span>installatører fordelt på {cities.length} byer</span>
    </aside>
  </section>

  <section class="container city-section">
    {cities.length > 0 && !dbError && (
      <div class="surface city-search" data-city-search>
        <div class="city-search__content">
          <span class="pill">Hurtig søgning</span>
          <h2>Find din by direkte</h2>
          <p>Søg efter bynavn eller postnummer, og gå direkte til den lokale oversigt.</p>
        </div>
        <div class="city-combobox">
          <label for="city-search-input">Søg efter by eller postnummer</label>
          <div class="city-combobox__field">
            <div class="city-combobox__control">
              <input
                id="city-search-input"
                type="search"
                name="city"
                placeholder="Fx Aarhus eller 8000"
                autocomplete="off"
                role="combobox"
                aria-autocomplete="list"
                aria-expanded="false"
                aria-controls="city-search-results"
                data-city-search-input
              />
              <span aria-hidden="true">Søg</span>
            </div>
            <div id="city-search-results" class="city-combobox__results" role="listbox" hidden data-city-search-results></div>
          </div>
          <p class="city-combobox__hint">Brug piletasterne til at vælge og Enter for at åbne en by.</p>
        </div>
      </div>
    )}

    <div class="section-heading">
      <span class="pill">Byer</span>
      <h2>Vælg by</h2>
      <p>Listen opdateres automatisk ud fra installatørerne i databasen.</p>
    </div>

    {dbError ? (
      <div class="surface notice" role="alert">
        <strong>Databaseforbindelsen mangler eller fejlede.</strong>
        <p>{dbError}</p>
      </div>
    ) : cities.length > 0 ? (
      <div class="city-grid">
        {cities.map((city) => (
          <a class="surface city-card" href={`/varmepumpe-installatoer/${city.slug}/`}>
            <span>{city.name}</span>
            <strong>{city.companyCount} {city.companyCount === 1 ? 'installatør' : 'installatører'}</strong>
          </a>
        ))}
      </div>
    ) : (
      <div class="surface notice">
        <strong>Ingen byer fundet endnu.</strong>
        <p>Importer scrapedata til PostgreSQL, og sørg for at virksomhederne har en by.</p>
      </div>
    )}
  </section>
</BaseLayout>

<script type="application/json" id="city-search-data" set:html={citySearchJson}></script>

<script>
  const searchRoot = document.querySelector('[data-city-search]');
  const dataElement = document.getElementById('city-search-data');

  if (searchRoot instanceof HTMLElement && dataElement?.textContent) {
    const input = searchRoot.querySelector('[data-city-search-input]');
    const results = searchRoot.querySelector('[data-city-search-results]');
    const cities = JSON.parse(dataElement.textContent);
    let activeIndex = -1;
    let currentMatches = [];

    const normalize = (value) => value.toLocaleLowerCase('da-DK').trim();
    const resultId = (index) => `city-search-result-${index}`;

    const closeResults = () => {
      activeIndex = -1;
      input.setAttribute('aria-expanded', 'false');
      input.removeAttribute('aria-activedescendant');
      results.hidden = true;
    };

    const setActiveResult = (index) => {
      activeIndex = index;
      [...results.querySelectorAll('[role="option"]')].forEach((option, optionIndex) => {
        option.setAttribute('aria-selected', String(optionIndex === activeIndex));
      });

      if (activeIndex >= 0) {
        input.setAttribute('aria-activedescendant', resultId(activeIndex));
      } else {
        input.removeAttribute('aria-activedescendant');
      }
    };

    const getMatches = (query) => {
      const normalizedQuery = normalize(query);
      if (!normalizedQuery) return [];

      return cities
        .filter((city) => {
          const cityName = normalize(city.name);
          const postalCodes = city.postalCodes ?? [];
          return cityName.includes(normalizedQuery) || postalCodes.some((postalCode) => normalize(postalCode).startsWith(normalizedQuery));
        })
        .sort((a, b) => {
          const aName = normalize(a.name);
          const bName = normalize(b.name);
          const aStartsWith = aName.startsWith(normalizedQuery) ? 0 : 1;
          const bStartsWith = bName.startsWith(normalizedQuery) ? 0 : 1;
          return aStartsWith - bStartsWith || aName.localeCompare(bName, 'da-DK');
        })
        .slice(0, 8);
    };

    const renderResults = () => {
      currentMatches = getMatches(input.value);
      results.innerHTML = '';

      if (!input.value.trim()) {
        closeResults();
        return;
      }

      if (currentMatches.length === 0) {
        results.innerHTML = '<div class="city-combobox__empty">Ingen by fundet. Prøv en nærliggende større by.</div>';
        input.setAttribute('aria-expanded', 'true');
        input.removeAttribute('aria-activedescendant');
        results.hidden = false;
        activeIndex = -1;
        return;
      }

      currentMatches.forEach((city, index) => {
        const link = document.createElement('a');
        const textWrap = document.createElement('span');
        const cityName = document.createElement('strong');
        const companyCount = document.createElement('em');
        const postalCodes = city.postalCodes ?? [];
        const visiblePostalCodes = postalCodes.slice(0, 3).join(', ');
        const extraPostalCodes = postalCodes.length > 3 ? ` +${postalCodes.length - 3} flere` : '';

        link.id = resultId(index);
        link.className = 'city-combobox__option';
        link.href = `/varmepumpe-installatoer/${city.slug}/`;
        link.setAttribute('role', 'option');
        link.setAttribute('aria-selected', 'false');
        cityName.textContent = city.name;
        textWrap.append(cityName);

        if (visiblePostalCodes) {
          const postalCodeText = document.createElement('small');
          postalCodeText.textContent = `${visiblePostalCodes}${extraPostalCodes}`;
          textWrap.append(postalCodeText);
        }

        companyCount.textContent = `${city.companyCount} ${city.companyCount === 1 ? 'installatør' : 'installatører'}`;
        link.append(textWrap, companyCount);
        link.addEventListener('mouseenter', () => setActiveResult(index));
        results.append(link);
      });

      input.setAttribute('aria-expanded', 'true');
      results.hidden = false;
      setActiveResult(0);
    };

    input.addEventListener('input', renderResults);
    input.addEventListener('focus', renderResults);
    input.addEventListener('keydown', (event) => {
      if (results.hidden && ['ArrowDown', 'ArrowUp', 'Enter'].includes(event.key)) {
        renderResults();
      }

      if (event.key === 'Escape') {
        closeResults();
        return;
      }

      if (!currentMatches.length) return;

      if (event.key === 'ArrowDown') {
        event.preventDefault();
        setActiveResult((activeIndex + 1) % currentMatches.length);
      }

      if (event.key === 'ArrowUp') {
        event.preventDefault();
        setActiveResult((activeIndex - 1 + currentMatches.length) % currentMatches.length);
      }

      if (event.key === 'Enter' && activeIndex >= 0) {
        event.preventDefault();
        window.location.href = `/varmepumpe-installatoer/${currentMatches[activeIndex].slug}/`;
      }
    });

    document.addEventListener('click', (event) => {
      if (!searchRoot.contains(event.target)) closeResults();
    });
  }
</script>

<style>
  .directory-hero { display: grid; grid-template-columns: minmax(0, 1fr) minmax(260px, 0.35fr); gap: 2rem; align-items: end; }
  .directory-hero p { max-width: 820px; color: var(--color-muted); font-size: clamp(1.08rem, 2vw, 1.28rem); }
  .stats-card { padding: 1.35rem; }
  .stats-card strong { display: block; color: var(--color-primary); font-size: clamp(2.4rem, 5vw, 4rem); line-height: 1; letter-spacing: -0.06em; }
  .stats-card span { display: block; margin-top: 0.65rem; color: var(--color-muted); font-weight: 800; }
  .city-section { padding-bottom: clamp(3.5rem, 7vw, 7rem); }
  .city-search { display: grid; grid-template-columns: minmax(0, 0.85fr) minmax(320px, 1fr); gap: clamp(1rem, 3vw, 2rem); align-items: center; margin-bottom: 2rem; padding: clamp(1.1rem, 3vw, 1.6rem); }
  .city-search__content h2 { margin: 0.8rem 0 0.55rem; font-size: clamp(1.8rem, 3vw, 2.6rem); }
  .city-search__content p { margin: 0; color: var(--color-muted); font-size: 1.05rem; }
  .city-combobox { position: relative; }
  .city-combobox label { display: block; margin-bottom: 0.5rem; color: var(--color-primary); font-weight: 900; }
  .city-combobox__field { position: relative; }
  .city-combobox__control { display: flex; align-items: center; gap: 0.75rem; border: 1px solid var(--color-border); border-radius: 999px; background: var(--color-surface-strong); padding: 0.35rem 0.45rem 0.35rem 1rem; transition: border-color 160ms ease, box-shadow 160ms ease; }
  .city-combobox__control:focus-within { border-color: var(--color-accent); box-shadow: 0 0 0 4px color-mix(in srgb, var(--color-accent) 18%, transparent); }
  .city-combobox__control input { width: 100%; min-width: 0; border: 0; outline: 0; background: transparent; color: var(--color-primary); font: inherit; font-weight: 800; }
  .city-combobox__control input::placeholder { color: var(--color-muted); opacity: 0.75; }
  .city-combobox__control span { border-radius: 999px; background: var(--color-primary); color: var(--color-background); padding: 0.65rem 1rem; font-weight: 900; white-space: nowrap; }
  .city-combobox__results { position: absolute; z-index: 20; top: calc(100% + 0.5rem); left: 0; right: 0; overflow: hidden; border: 1px solid var(--color-border); border-radius: 1rem; background: var(--color-surface); box-shadow: 0 18px 45px rgba(15, 23, 42, 0.16); }
  :global(.city-combobox__option) { display: flex; justify-content: space-between; align-items: center; gap: 1rem; border-left: 4px solid transparent; padding: 0.9rem 1rem; color: var(--color-primary); text-decoration: none; transition: background 140ms ease, border-color 140ms ease; }
  :global(.city-combobox__option + .city-combobox__option) { border-top: 1px solid var(--color-border); }
  :global(.city-combobox__option[aria-selected="true"]), :global(.city-combobox__option:hover) { border-left-color: var(--color-accent); background: var(--color-accent-soft); color: var(--color-primary); }
  :global(.city-combobox__option span), :global(.city-combobox__option strong), :global(.city-combobox__option small) { display: block; }
  :global(.city-combobox__option strong) { font-size: 1rem; }
  :global(.city-combobox__option small) { margin-top: 0.2rem; color: var(--color-muted); font-weight: 800; }
  :global(.city-combobox__option em) { color: var(--color-muted); font-size: 0.9rem; font-style: normal; font-weight: 900; white-space: nowrap; }
  :global(.city-combobox__empty) { padding: 1rem; color: var(--color-muted); font-weight: 800; }
  .city-combobox__hint { margin: 0.55rem 0 0; color: var(--color-muted); font-size: 0.9rem; }
  .section-heading { margin-bottom: 1.5rem; }
  .section-heading h2 { margin-top: 0.8rem; }
  .section-heading p { max-width: 720px; color: var(--color-muted); font-size: 1.08rem; }
  .city-grid { display: grid; grid-template-columns: repeat(3, minmax(0, 1fr)); gap: 1rem; }
  .city-card { display: flex; justify-content: space-between; gap: 1rem; padding: 1rem 1.1rem; color: var(--color-primary); text-decoration: none; transition: border-color 160ms ease, transform 160ms ease; }
  .city-card:hover { border-color: var(--color-accent); color: var(--color-primary); transform: translateY(-2px); }
  .city-card span { font-weight: 900; }
  .city-card strong { color: var(--color-muted); font-size: 0.92rem; white-space: nowrap; }
  .notice { padding: 1.25rem; }
  .notice strong { color: var(--color-primary); }
  .notice p { margin: 0.5rem 0 0; color: var(--color-muted); }
  @media (max-width: 860px) { .directory-hero, .city-search, .city-grid { grid-template-columns: 1fr; } }
  @media (max-width: 560px) { .city-combobox__control { border-radius: 1rem; } .city-combobox__control span { display: none; } :global(.city-combobox__option) { flex-direction: column; align-items: flex-start; gap: 0.35rem; } }
</style>
