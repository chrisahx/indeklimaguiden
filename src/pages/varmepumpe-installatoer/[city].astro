---
export const prerender = false;

import Breadcrumbs from '../../components/Breadcrumbs.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getPrisma } from '../../lib/prisma';
import { slugifyCity } from '../../lib/slugs';

interface CityRow {
  city_name: string;
}

interface CompanyRow {
  id: string;
  slug: string;
  name: string;
  website: string | null;
  phone: string | null;
  email: string | null;
  cvr: string | null;
  address: string | null;
  city: string;
  latitude: string | null;
  longitude: string | null;
  google_rating: string | null;
  google_review_count: number | null;
  trustpilot_rating: string | null;
  trustpilot_review_count: number | null;
}

const citySlug = Astro.params.city ?? '';
let cityName = '';
let companies: CompanyRow[] = [];
let dbError = '';

try {
  const prisma = getPrisma();
  const cityRows = await prisma.$queryRaw<CityRow[]>`
    select min(trim(company_locations.city)) as city_name
    from company_locations
    join companies on companies.id = company_locations.company_id
    where companies.is_published = true
      and company_locations.city is not null
      and trim(company_locations.city) != ''
    group by lower(trim(company_locations.city))
    order by city_name asc
  `;

  const matchedCity = cityRows.find((row) => slugifyCity(row.city_name) === citySlug);

  if (!matchedCity) {
    return new Response('Byen blev ikke fundet.', { status: 404 });
  }

  cityName = matchedCity.city_name;

  const rows = await prisma.$queryRaw<CompanyRow[]>`
    select
      companies.id,
      companies.slug,
      companies.name,
      companies.website,
      companies.phone,
      companies.email,
      companies.cvr,
      company_locations.address,
      company_locations.city,
      company_locations.latitude::text as latitude,
      company_locations.longitude::text as longitude,
      google.rating::text as google_rating,
      google.review_count as google_review_count,
      trustpilot.rating::text as trustpilot_rating,
      trustpilot.review_count as trustpilot_review_count
    from companies
    join company_locations on company_locations.company_id = companies.id
    left join company_sources google
      on google.company_id = companies.id and google.source = 'google'
    left join company_sources trustpilot
      on trustpilot.company_id = companies.id and trustpilot.source = 'trustpilot'
    where companies.is_published = true
      and lower(trim(company_locations.city)) = lower(trim(${cityName}))
    order by companies.name asc
  `;

  companies = rows;
} catch (error) {
  dbError = error instanceof Error ? error.message : 'Kunne ikke hente installatører fra databasen.';
}

const title = cityName ? `Varmepumpe installatører i ${cityName}` : 'Varmepumpe installatører';
const description = cityName
  ? `Find varmepumpe installatører i ${cityName}. Se lokale virksomheder, kontaktoplysninger og offentligt indsamlede anmeldelsesdata.`
  : 'Find lokale varmepumpe installatører og kontaktoplysninger.';
---

<BaseLayout title={title} description={description} path={`/varmepumpe-installatoer/${citySlug}/`}>
  <section class="section container city-hero">
    <Breadcrumbs items={[{ name: 'Forside', url: '/' }, { name: 'Varmepumpe installatører', url: '/varmepumpe-installatoer/' }, { name: cityName || 'By', url: `/varmepumpe-installatoer/${citySlug}/` }]} />
    <span class="pill">Lokal oversigt</span>
    <h1>{cityName ? `Varmepumpe installatører i ${cityName}` : 'Varmepumpe installatører'}</h1>
    <p>
      Sammenlign lokale installatører, kontaktoplysninger og anmeldelsesdata. Brug oversigten som startpunkt, og verificér altid autorisation, opgaveomfang og pris direkte med virksomheden.
    </p>
  </section>

  <section class="container listing-section">
    {dbError ? (
      <div class="surface notice" role="alert">
        <strong>Databaseforbindelsen mangler eller fejlede.</strong>
        <p>{dbError}</p>
      </div>
    ) : (
      <>
        <div class="section-heading">
          <span class="pill">{companies.length} {companies.length === 1 ? 'virksomhed' : 'virksomheder'}</span>
          <h2>Installatører i {cityName}</h2>
        </div>

        {companies.length > 0 ? (
          <div class="company-list">
            {companies.map((company) => (
              <article class="surface company-card">
                <div>
                  <h2>{company.name}</h2>
                  <p class="address">{company.address || company.city}</p>
                  <dl class="ratings">
                    {company.google_rating && <div><dt>Google</dt><dd>{company.google_rating}{company.google_review_count ? ` (${company.google_review_count})` : ''}</dd></div>}
                    {company.trustpilot_rating && <div><dt>Trustpilot</dt><dd>{company.trustpilot_rating}{company.trustpilot_review_count ? ` (${company.trustpilot_review_count})` : ''}</dd></div>}
                    {company.cvr && <div><dt>CVR</dt><dd>{company.cvr}</dd></div>}
                  </dl>
                </div>
                <div class="actions">
                  {company.website && <a class="button" href={company.website} rel="nofollow noopener" target="_blank">Besøg website</a>}
                  {company.phone && <a class="button secondary" href={`tel:${company.phone.replace(/\s+/g, '')}`}>{company.phone}</a>}
                  {company.email && <a class="button secondary" href={`mailto:${company.email}`}>Send mail</a>}
                </div>
              </article>
            ))}
          </div>
        ) : (
          <div class="surface notice">
            <strong>Ingen publicerede installatører fundet i {cityName}.</strong>
            <p>Kontrollér importerede data, og sørg for at virksomhederne er markeret som publicerede.</p>
          </div>
        )}
      </>
    )}
  </section>

  <section class="container disclosure surface">
    <h2>Om data i oversigten</h2>
    <p>Data er indsamlet fra offentligt tilgængelige kilder og kan ændre sig. Kontakt altid virksomheden direkte for at bekræfte ydelser, priser, certificeringer og tilgængelighed.</p>
  </section>
</BaseLayout>

<style>
  .city-hero { padding-bottom: clamp(2rem, 4vw, 3rem); }
  .city-hero p { max-width: 820px; color: var(--color-muted); font-size: clamp(1.08rem, 2vw, 1.26rem); }
  .listing-section { padding-bottom: clamp(2rem, 5vw, 4rem); }
  .section-heading { margin-bottom: 1.5rem; }
  .section-heading h2 { margin-top: 0.8rem; }
  .company-list { display: grid; gap: 1rem; }
  .company-card { display: grid; grid-template-columns: minmax(0, 1fr) auto; gap: 1.5rem; padding: clamp(1rem, 2vw, 1.35rem); align-items: start; }
  .company-card h2 { margin: 0 0 0.5rem; font-size: clamp(1.35rem, 2.5vw, 2rem); }
  .address { color: var(--color-muted); }
  .ratings { display: flex; flex-wrap: wrap; gap: 0.75rem; margin: 1rem 0 0; }
  .ratings div { border: 1px solid var(--color-border); border-radius: 999px; padding: 0.45rem 0.7rem; background: var(--color-surface-strong); }
  .ratings dt, .ratings dd { display: inline; margin: 0; }
  .ratings dt { color: var(--color-muted); font-size: 0.82rem; font-weight: 800; text-transform: uppercase; letter-spacing: 0.04em; }
  .ratings dd { margin-left: 0.35rem; color: var(--color-primary); font-weight: 900; }
  .actions { display: flex; flex-direction: column; gap: 0.6rem; min-width: 180px; }
  .actions .button { width: 100%; padding: 0.75rem 1rem; }
  .notice { padding: 1.25rem; }
  .notice strong { color: var(--color-primary); }
  .notice p { margin: 0.5rem 0 0; color: var(--color-muted); }
  .disclosure { margin-bottom: clamp(3.5rem, 7vw, 7rem); padding: 1.25rem; }
  .disclosure h2 { margin: 0 0 0.75rem; font-size: 1.35rem; }
  .disclosure p { margin: 0; color: var(--color-muted); }
  @media (max-width: 760px) { .company-card { grid-template-columns: 1fr; } .actions { min-width: 0; } }
</style>
