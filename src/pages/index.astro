---
import ArticleCard from '../components/ArticleCard.astro';
import CategoryCard from '../components/CategoryCard.astro';
import BaseLayout from '../layouts/BaseLayout.astro';
import { articleUrl, getArticles } from '../lib/articles';
import { CATEGORIES } from '../lib/constants';

const allArticles = await getArticles();
const featuredArticles = allArticles.filter((article) => article.data.featured).slice(0, 3);
const nonFeaturedArticles = allArticles.filter((article) => !featuredArticles.includes(article));
const latestArticles = (nonFeaturedArticles.length > 0 ? nonFeaturedArticles : allArticles).slice(0, 6);

const topicLinks = [
  ['Mobil aircondition', '/aircondition/'],
  ['Luft til luft-varmepumpe', '/varmepumper/'],
  ['Luftfugtighed', '/indeklima/optimal-luftfugtighed-i-hjemmet/'],
  ['Strømforbrug', '/aircondition/'],
  ['Støjniveau', '/aircondition/'],
  ['Affugter', '/indeklima/'],
  ['Luftrenser', '/indeklima/'],
  ['Ventilation', '/indeklima/'],
];

const editorialPrinciples = [
  'Danske boligforhold',
  'Realistisk elforbrug',
  'Støj og komfort i hverdagen',
  'Pris, installation og drift',
  'Vedligeholdelse og levetid',
  'Tydelig annonce- og affiliateinfo',
];
---

<BaseLayout
  title="Indeklima Guiden | Guides, anmeldelser og købshjælp til bedre indeklima"
  description="Danske guides og anmeldelser om aircondition, varmepumper, luftfugtighed, ventilation og bedre indeklima. Få praktisk købshjælp til produkter og løsninger i hjemmet."
  path="/"
>
  <section class="editorial-intro">
    <div class="container intro-copy">
      <span class="pill">Dansk guide- og reviewsite</span>
      <h1>Guides, anmeldelser og praktisk købshjælp til bedre indeklima.</h1>
      <p>
        Indeklima Guiden hjælper danske boligejere og lejere med at vælge bedre løsninger til køling, varme, fugt og luftkvalitet. Her finder du praktiske guides, prissammenligninger, anmeldelser og forklaringer om <a href="/aircondition/">aircondition</a>, <a href="/varmepumper/">varmepumper</a> og <a href="/indeklima/">sundere indeklima</a>.
      </p>
    </div>
  </section>

  <section class="section container featured-section">
    <div class="section-heading split-heading">
      <div>
        <span class="pill">Start her</span>
        <h2>Udvalgte guides</h2>
      </div>
      <p>De vigtigste artikler for dig, der vil forstå muligheder, priser og praktiske valg, før du køber eller forbedrer indeklimaet.</p>
    </div>
    {featuredArticles.length > 0 ? (
      <div class="featured-grid">
        {featuredArticles.map((article, index) => (
          <article class={`featured-card surface ${index === 0 ? 'large' : ''}`}>
            <span class="card-kicker">{CATEGORIES[article.data.category].name}</span>
            <h2><a href={articleUrl(article)}>{article.data.title}</a></h2>
            <p>{article.data.description}</p>
            <a class="read-link" href={articleUrl(article)} aria-label={`Læs guiden: ${article.data.title}`}>Læs guiden</a>
          </article>
        ))}
      </div>
    ) : <p>Der er endnu ingen udvalgte guides.</p>}
  </section>

  {import.meta.env.DEV && (
    <aside class="container ad-slot" aria-label="Annonceplads">
      <span>Annonce</span>
    </aside>
  )}

  <section class="section container">
    <div class="section-heading">
      <span class="pill">Nyt på siden</span>
      <h2>Seneste guides og anmeldelser</h2>
      <p>Aktuelle forklaringer, købsguides og praktiske artikler om køling, varme, luftfugtighed og bedre indeklima i danske hjem.</p>
    </div>
    {latestArticles.length > 0 ? <div class="grid">{latestArticles.map((article) => <ArticleCard article={article} />)}</div> : <p>Der er endnu ingen publicerede artikler.</p>}
  </section>

  <section class="section container">
    <div class="section-heading">
      <span class="pill">Emner</span>
      <h2>Find guides efter område</h2>
      <p>Vælg det område, der passer til dit problem: køling, opvarmning, fugt, ventilation, luftkvalitet eller totaløkonomi.</p>
    </div>
    <div class="grid">
      {Object.values(CATEGORIES).map((category) => (
        <CategoryCard title={category.name} description={category.description} href={`/${category.slug}/`} />
      ))}
    </div>
  </section>

  {import.meta.env.DEV && (
    <aside class="container ad-slot compact" aria-label="Annonceplads">
      <span>Annonce</span>
    </aside>
  )}

  <section class="section container topics-section">
    <div class="section-heading">
      <span class="pill">Populære emner</span>
      <h2>Hurtige veje ind i guiden</h2>
    </div>
    <div class="topic-list" aria-label="Populære emner på Indeklima Guiden">
      {topicLinks.map(([label, href]) => <a href={href}>{label}</a>)}
    </div>
  </section>

  <section class="section container method">
    <div>
      <span class="pill">Redaktionel metode</span>
      <h2>Sådan arbejder vi med guides og anmeldelser.</h2>
      <p>
        Artiklerne er skrevet til danske boligejere og lejere, der vil forstå forskellen på markedsføring og reel hverdagsværdi. Vi prioriterer praktiske forhold som støj, elforbrug, rumstørrelse, installation og vedligeholdelse.
      </p>
    </div>
    <div class="method-grid">
      {editorialPrinciples.map((item) => (
        <div class="method-card surface">
          <span aria-hidden="true"></span>
          <strong>{item}</strong>
        </div>
      ))}
    </div>
  </section>
</BaseLayout>

<style>
  .editorial-intro { padding: clamp(4rem, 8vw, 7rem) 0 clamp(2.25rem, 5vw, 4rem); }
  .intro-copy { text-align: center; }
  .editorial-intro h1 { max-width: 980px; margin: 0.85rem auto 1rem; font-size: clamp(2.65rem, 6vw, 5.35rem); }
  .editorial-intro p { max-width: 860px; margin-inline: auto; color: var(--color-muted); font-size: clamp(1.08rem, 2vw, 1.32rem); }
  .featured-section { padding-top: clamp(2.5rem, 5vw, 4rem); }
  .section-heading { margin-bottom: 1.5rem; }
  .section-heading h2 { margin-top: 0.8rem; }
  .section-heading p { max-width: 760px; color: var(--color-muted); font-size: 1.1rem; }
  .split-heading { display: flex; justify-content: space-between; gap: 2rem; align-items: end; }
  .featured-grid { display: grid; grid-template-columns: minmax(0, 1.15fr) minmax(0, 0.85fr); gap: 1.15rem; }
  .featured-card { display: flex; min-height: 235px; flex-direction: column; padding: 1.25rem; }
  .featured-card.large { grid-row: span 2; min-height: 100%; padding: clamp(1.4rem, 3vw, 2rem); background: linear-gradient(145deg, rgba(255, 255, 255, 0.96), rgba(220, 251, 255, 0.74)); }
  .featured-card h2 { margin: 0.8rem 0 0.75rem; font-size: clamp(1.45rem, 3vw, 2.25rem); }
  .featured-card h2 a { color: var(--color-primary); text-decoration: none; }
  .featured-card p { color: var(--color-muted); }
  .card-kicker { width: fit-content; border-radius: 999px; padding: 0.22rem 0.6rem; background: var(--color-accent-soft); color: var(--color-accent-dark); font-size: 0.76rem; font-weight: 850; letter-spacing: 0.06em; text-transform: uppercase; }
  .read-link { margin-top: auto; color: var(--color-primary); font-weight: 850; text-decoration: none; }
  .read-link:hover { color: var(--color-accent-dark); }
  .ad-slot { display: grid; min-height: 92px; place-items: center; border: 1px dashed var(--color-border-strong); border-radius: var(--radius-lg); background: rgba(255, 255, 255, 0.46); color: var(--color-muted); font-size: 0.78rem; font-weight: 800; letter-spacing: 0.08em; text-transform: uppercase; }
  .ad-slot.compact { min-height: 76px; }
  .topics-section { padding-top: clamp(2.75rem, 5vw, 4.5rem); }
  .topic-list { display: flex; flex-wrap: wrap; gap: 0.75rem; }
  .topic-list a { border: 1px solid var(--color-border); border-radius: 999px; padding: 0.7rem 1rem; background: rgba(255, 255, 255, 0.72); color: var(--color-primary); font-weight: 800; text-decoration: none; transition: border-color 160ms ease, transform 160ms ease, background 160ms ease; }
  .topic-list a:hover { border-color: var(--color-accent); background: var(--color-accent-soft); transform: translateY(-2px); }
  .method { display: grid; grid-template-columns: minmax(0, 0.9fr) minmax(0, 1.1fr); gap: 2rem; align-items: start; }
  .method h2 { margin: 0.8rem 0 1rem; }
  .method p { color: var(--color-muted); font-size: 1.1rem; }
  .method-grid { display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 0.9rem; padding-top: 3.15rem; }
  .method-card { display: flex; align-items: center; gap: 0.75rem; padding: 1rem; }
  .method-card span { width: 0.7rem; height: 0.7rem; border-radius: 999px; background: var(--color-accent); box-shadow: 0 0 0 6px rgba(32, 199, 215, 0.14); }
  @media (max-width: 860px) { .featured-grid, .method { grid-template-columns: 1fr; } .split-heading { display: block; } .method-grid { padding-top: 0; } }
  @media (max-width: 560px) { .method-grid { grid-template-columns: 1fr; } }
</style>
