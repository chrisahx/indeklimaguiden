---
import ArticleCard from '../../components/ArticleCard.astro';
import CategoryCard from '../../components/CategoryCard.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getArticlesByType } from '../../lib/articles';
import { CATEGORIES } from '../../lib/constants';

const articles = await getArticlesByType('guide');
---

<BaseLayout
  title="Guides om aircondition, varmepumper og indeklima"
  description="Find praktiske danske guides om aircondition, varmepumper og indeklima. Vælg emne eller læs de nyeste guides."
  path="/guides/"
>
  <section class="section container page-head">
    <span class="pill">Guides</span>
    <h1>Guides til bedre indeklima</h1>
    <p>Praktiske forklaringer, købshjælp og trin-for-trin viden om køling, varme, luftfugtighed, ventilation og luftkvalitet i danske hjem.</p>
  </section>

  <section class="container section-list">
    <div class="section-heading">
      <span class="pill">Vælg område</span>
      <h2>Guidekategorier</h2>
    </div>
    <div class="grid">
      {Object.values(CATEGORIES).map((category) => <CategoryCard title={category.name} description={category.description} href={`/guides/${category.slug}/`} />)}
    </div>
  </section>

  <section class="container section-list">
    <div class="section-heading">
      <span class="pill">Seneste</span>
      <h2>Alle guides</h2>
    </div>
    {articles.length > 0 ? <div class="grid">{articles.map((article) => <ArticleCard article={article} />)}</div> : <p>Der er endnu ingen publicerede guides.</p>}
  </section>
</BaseLayout>

<style>
  .page-head { padding-bottom: 2rem; }
  .page-head p { max-width: 780px; color: var(--color-muted); font-size: 1.16rem; }
  .section-list { padding-bottom: clamp(3rem, 7vw, 6rem); }
  .section-list + .section-list { padding-top: 0; }
  .section-heading { margin-bottom: 1.5rem; }
  .section-heading h2 { margin-top: 0.8rem; }
</style>
