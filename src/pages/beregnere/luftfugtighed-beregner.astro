---
import AnswerBox from '../../components/AnswerBox.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import FAQ from '../../components/FAQ.astro';
import GoogleAd from '../../components/GoogleAd.astro';
import JsonLd from '../../components/JsonLd.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { absoluteUrl } from '../../lib/seo';
import { breadcrumbsJsonLd, faqJsonLd } from '../../lib/structured-data';

const path = '/beregnere/luftfugtighed-beregner/';
const sidebarAdSlot = import.meta.env.PUBLIC_ADSENSE_SLOT_CALCULATOR_SIDEBAR;
const wideAdSlot = import.meta.env.PUBLIC_ADSENSE_SLOT_CALCULATOR_WIDE;
const articleAdSlot = import.meta.env.PUBLIC_ADSENSE_SLOT_CALCULATOR_ARTICLE;
const mobileAdSlotOne = import.meta.env.PUBLIC_ADSENSE_SLOT_CALCULATOR_MOBILE_1;
const mobileAdSlotTwo = import.meta.env.PUBLIC_ADSENSE_SLOT_CALCULATOR_MOBILE_2;
const leftRailAdSlot = import.meta.env.PUBLIC_ADSENSE_SLOT_CALCULATOR_LEFT_RAIL;
const rightRailAdSlot = import.meta.env.PUBLIC_ADSENSE_SLOT_CALCULATOR_RIGHT_RAIL;
const showSidebarAd = import.meta.env.DEV || sidebarAdSlot;
const showWideAd = import.meta.env.DEV || wideAdSlot;
const showArticleAd = import.meta.env.DEV || articleAdSlot;
const showMobileAdOne = import.meta.env.DEV || mobileAdSlotOne;
const showMobileAdTwo = import.meta.env.DEV || mobileAdSlotTwo;
const showLeftRailAd = import.meta.env.DEV || leftRailAdSlot;
const showRightRailAd = import.meta.env.DEV || rightRailAdSlot;
const breadcrumbs = [
  { name: 'Forside', url: '/' },
  { name: 'Beregnere', url: '/beregnere/' },
  { name: 'Luftfugtighed beregner', url: path },
];
const faq = [
  {
    question: 'Hvad er normal luftfugtighed indendørs?',
    answer:
      'Normal luftfugtighed indendørs ligger typisk omkring 40-60 % relativ luftfugtighed. Om vinteren kan 30-45 % være almindeligt, mens vedvarende niveauer over 60 % øger risikoen for fugtproblemer.',
  },
  {
    question: 'Hvornår er luftfugtigheden for høj i soveværelset?',
    answer:
      'Luftfugtigheden er ofte for høj i soveværelset, hvis den ligger over 60 % i længere tid, især hvis der samtidig er dug på ruder, tung luft eller begyndende skimmel.',
  },
  {
    question: 'Kan en luftfugtighed beregner vise skimmelrisiko?',
    answer:
      'En beregner kan give et vejledende risikoniveau ud fra temperatur, relativ luftfugtighed, rumtype og symptomer. Den erstatter ikke en fugtmåling i konstruktioner eller en byggesagkyndig vurdering.',
  },
  {
    question: 'Hvad gør man ved for høj luftfugtighed?',
    answer:
      'Start med kort, effektiv udluftning, brug udsugning ved bad og madlavning, hold jævn varme og fjern fugtkilder. Ved kælder, badeværelse eller vedvarende fugt kan affugter eller dry mode være relevant.',
  },
  {
    question: 'Hvad gør man ved for lav luftfugtighed?',
    answer:
      'For lav luftfugtighed håndteres ofte med lavere overopvarmning, bedre ventilation uden konstant træk og færre støvkilder. Luftfugter bør bruges forsigtigt, så fugtniveauet ikke bliver for højt.',
  },
];

const calculatorJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  name: 'Luftfugtighed beregner og indeklima-tjek',
  description:
    'Test dit indeklima på 30 sekunder. Indtast temperatur, relativ luftfugtighed, rumtype og symptomer, og få en vurdering af fugtniveau, kondensrisiko og relevante løsninger.',
  url: absoluteUrl(path),
  applicationCategory: 'CalculatorApplication',
  operatingSystem: 'Web',
  inLanguage: 'da-DK',
  offers: {
    '@type': 'Offer',
    price: '0',
    priceCurrency: 'DKK',
  },
};
---

<BaseLayout
  title="Luftfugtighed beregner: Test dit indeklima på 30 sekunder"
  description="Brug vores luftfugtighed beregner og indeklima-tjek. Indtast temperatur, relativ luftfugtighed, rumtype og symptomer, og se om luften er lav, normal eller høj."
  path={path}
>
  <section class="calculator-hero">
    <div class="container hero-copy">
      <Breadcrumbs items={breadcrumbs} />
      <span class="pill">Luftfugtighed beregner</span>
      <h1>Test dit indeklima på 30 sekunder</h1>
      <p>
        Indtast temperatur, relativ luftfugtighed og de symptomer du oplever. Beregneren vurderer, om luftfugtigheden er lav, normal eller høj, og hvad du bør gøre som næste skridt.
      </p>
      <div class="hero-actions">
        <a class="button" href="#beregner">Start indeklima-tjek</a>
        <a class="button secondary" href="#normal-luftfugtighed">Se normal luftfugtighed</a>
      </div>
      <aside class="surface quick-answer" aria-label="Kort svar">
        <span class="pill">Kort svar</span>
        <p>
          Normal luftfugtighed indendørs er typisk <strong>40-60 %</strong>. Vedvarende fugt over 60 % kan give kondens og skimmelrisiko, mens meget lav fugt kan føles tør for hals, hud og øjne.
        </p>
      </aside>
    </div>
  </section>

  <section id="beregner" class="section container calculator-section" aria-labelledby="calculator-heading">
    <div class="section-heading">
      <span class="pill">Indeklima-tjek</span>
      <h2 id="calculator-heading">Beregn din luftfugtighed og risiko</h2>
      <p>Resultatet er vejledende og bygger på typiske grænser for relativ luftfugtighed, rumtype og synlige symptomer.</p>
    </div>

    <div class:list={['calculator-layout', showSidebarAd && 'has-sidebar-ad']}>
      <div class="surface calculator-panel">
        <form class="calculator-form" data-calculator novalidate>
          <div class="field-grid">
            <label>
              <span>Temperatur i rummet</span>
              <input name="temperature" type="number" inputmode="decimal" min="10" max="32" step="0.5" value="21" required />
            </label>
            <label>
              <span class="label-with-help">
                Relativ luftfugtighed i %
                <span class="tooltip">
                  <button type="button" class="tooltip-trigger" aria-describedby="humidity-help">?</button>
                  <span id="humidity-help" class="tooltip-content" role="tooltip">
                    Brug et hygrometer, en vejrstation eller en smart indeklimamåler. Du kan også se fugtigheden for dit område på <a href="https://dmi.dk" target="_blank" rel="noopener noreferrer">DMI</a>. Mål midt i rummet, væk fra radiator, sol og åbne vinduer.
                  </span>
                </span>
              </span>
              <input name="humidity" type="number" inputmode="decimal" min="15" max="95" step="1" value="55" required />
            </label>
            <label class="wide">
              <span>Rumtype</span>
              <select name="room">
                <option value="bedroom" selected>Soveværelse</option>
                <option value="basement">Kælder</option>
                <option value="living">Stue</option>
                <option value="bathroom">Badeværelse</option>
              </select>
            </label>
          </div>

          <fieldset class="symptom-fieldset">
            <legend>Hvilke symptomer oplever du?</legend>
            <label class="checkbox-label"><input name="symptoms" type="checkbox" value="condensation" /> Dug på ruder</label>
            <label class="checkbox-label"><input name="symptoms" type="checkbox" value="dryThroat" /> Tør hals eller tørre øjne</label>
            <label class="checkbox-label"><input name="symptoms" type="checkbox" value="mold" /> Skimmel eller mørke pletter</label>
            <label class="checkbox-label"><input name="symptoms" type="checkbox" value="heavyAir" /> Tung eller indelukket luft</label>
          </fieldset>

          <p class="form-error" data-error hidden>Udfyld venligst realistiske værdier for temperatur og relativ luftfugtighed.</p>
          <button class="button" type="submit">Beregn indeklima</button>
        </form>

        <aside class="result-card" aria-live="polite" data-result>
          <div>
            <span class="pill">Dit resultat</span>
            <p class="result-kicker" data-status-label>Normal luftfugtighed</p>
          </div>
          <div class="result-main">
            <strong data-main-result>Normal</strong>
            <p data-range-result>55 % relativ luftfugtighed ved 21 °C ligger typisk i komfortområdet.</p>
          </div>
          <p class="risk-summary" data-risk-result>Lav til moderat risiko for kondens, hvis niveauet ikke er konstant højt.</p>
        </aside>

        <div class="recommendation-card" data-recommendations>
          <h3>Anbefalinger</h3>
          <ul>
            <li>Hold øje med om fugten bliver liggende over 60 % flere dage i træk.</li>
            <li>Luft kort og effektivt ud, især morgen og aften.</li>
          </ul>
        </div>
      </div>

      {showSidebarAd && (
        <aside class="ad-column" aria-label="Annonce">
          <GoogleAd slotId={sidebarAdSlot} className="sidebar-ad" />
        </aside>
      )}
    </div>
  </section>

  {showWideAd && (
    <aside class="container" aria-label="Annonce">
      <GoogleAd slotId={wideAdSlot} className="wide-ad" />
    </aside>
  )}

  <article class:list={['article-shell', (showLeftRailAd || showRightRailAd) && 'has-rail-ads']}>
    {showLeftRailAd && (
      <aside class="rail-ad left-rail" aria-label="Annonce">
        <GoogleAd slotId={leftRailAdSlot} className="rail-ad-unit" />
      </aside>
    )}

    <div class="article-main">
      <aside class="reading side-panel">
        <div class="checklist">
          <h2>Det vurderer beregneren</h2>
          <ul>
            <li>Temperatur og relativ luftfugtighed</li>
            <li>Om fugtniveauet er lavt, normalt eller højt</li>
            <li>Rumtype: soveværelse, kælder, stue eller badeværelse</li>
            <li>Symptomer som dug, tør hals, skimmel og tung luft</li>
            <li>Risiko for kondens og skimmel</li>
            <li>Om ventilation, affugter, dry mode eller bedre udluftning bør overvejes</li>
          </ul>
        </div>
      </aside>

      <div class="reading article-body content-card">
        <AnswerBox>
          En luftfugtighed beregner kan hurtigt vise, om dit indeklima peger mod tør luft, normalt fugtniveau eller for høj fugt. Det vigtigste er ikke kun tallet på hygrometeret, men også rumtype og symptomer som dug på ruder, tung luft eller skimmel.
        </AnswerBox>

        {showMobileAdOne && <GoogleAd slotId={mobileAdSlotOne} className="calculator-mobile-ad" />}

        <h2 id="normal-luftfugtighed">Hvad er normal luftfugtighed indendørs?</h2>
        <p>
          Normal luftfugtighed indendørs ligger for de fleste hjem omkring 40-60 % relativ luftfugtighed. Det er et praktisk komfortområde, hvor luften sjældent føles meget tør, og hvor risikoen for kondens normalt er lavere end ved vedvarende høj fugt.
        </p>
        <p>
          Tallet skal dog læses sammen med temperaturen. 60 % ved 16 °C i en kølig kælder er mere kritisk end 60 % ved 22 °C i en varm stue, fordi kolde overflader øger risikoen for kondens.
        </p>

        <h2>For høj luftfugtighed i soveværelse, kælder og badeværelse</h2>
        <p>
          For høj luftfugtighed i soveværelse viser sig ofte som dug på ruder om morgenen, tung luft eller mørke pletter ved kolde hjørner. I kældre er risikoen højere, fordi vægge og gulve ofte er køligere, og fordi fugt kan komme både indefra og udefra.
        </p>
        <p>
          Badeværelser får naturligt fugtspidser efter bad. Det afgørende er, om fugten hurtigt falder igen. Hvis rummet forbliver fugtigt længe efter bad, bør udsugning, opvarmning og udluftningsvaner gennemgås.
        </p>

        <table>
          <thead>
            <tr>
              <th>Luftfugtighed</th>
              <th>Typisk vurdering</th>
              <th>Mulig handling</th>
            </tr>
          </thead>
          <tbody>
            <tr>
              <td>Under 35 %</td>
              <td>Lav luftfugtighed</td>
              <td>Undgå overopvarmning, reducer støv og vurder ventilation.</td>
            </tr>
            <tr>
              <td>40-60 %</td>
              <td>Normal luftfugtighed</td>
              <td>Fortsæt med jævn varme og korte, effektive udluftninger.</td>
            </tr>
            <tr>
              <td>Over 60 %</td>
              <td>Høj luftfugtighed</td>
              <td>Øg ventilation, fjern fugtkilder og overvej affugtning ved vedvarende problem.</td>
            </tr>
          </tbody>
        </table>

        <h2>Dårligt indeklima test: hvad betyder symptomerne?</h2>
        <p>
          Et dårligt indeklima kan skyldes både fugt, manglende ventilation, støv, temperatur og luftbevægelse. Dug på ruder peger ofte mod fugt og kolde overflader. Tør hals kan pege mod lav luftfugtighed, støv eller for høj temperatur. Tung luft handler ofte om utilstrækkelig udluftning.
        </p>
        <p>
          Hvis du ser skimmel, bør du ikke nøjes med at justere ventilationen. Find fugtkilden, rengør korrekt, og få hjælp ved større eller tilbagevendende områder.
        </p>

        <h2>Ventilation, affugter, dry mode eller varmepumpe?</h2>
        <p>
          Den rigtige løsning afhænger af årsagen. Ved almindelig fugt fra mennesker, bad og madlavning er bedre udluftning og udsugning ofte første skridt. Ved kælderfugt eller vedvarende høj fugt kan en affugter være mere relevant; se også vores <a href="/guides/indeklima/">guides til indeklima</a>.
        </p>
        <p>
          En <a href="/aircondition/">aircondition</a> eller <a href="/varmepumper/">luft til luft-varmepumpe</a> med dry mode kan hjælpe med at sænke fugtniveauet i perioder, men den løser ikke nødvendigvis årsagen til fugten. Hvis du også undersøger køling eller opvarmning, kan du bruge vores <a href="/beregnere/aircondition-varmepumpe-stoerrelse/">beregner til aircondition og varmepumpe størrelse</a>.
        </p>

        {showMobileAdTwo && <GoogleAd slotId={mobileAdSlotTwo} className="calculator-mobile-ad" />}

        {showArticleAd && <GoogleAd slotId={articleAdSlot} className="article-ad" />}

        <h2>Sådan bruger du beregneren korrekt</h2>
        <p>
          Mål luftfugtigheden med et hygrometer placeret væk fra direkte sol, radiatorer og åbne vinduer. Tag gerne flere målinger morgen og aften, fordi luftfugtigheden skifter med aktivitet, temperatur og vejret udenfor.
        </p>
        <p>
          Beregneren er bedst som et hurtigt indeklima-tjek. Ved skjult fugt, synlig skimmel, vandskade eller mistanke om problemer i konstruktionen bør du få en konkret vurdering.
        </p>

        <FAQ items={faq} />
      </div>
    </div>

    {showRightRailAd && (
      <aside class="rail-ad right-rail" aria-label="Annonce">
        <GoogleAd slotId={rightRailAdSlot} className="rail-ad-unit" />
      </aside>
    )}
  </article>

  <JsonLd data={breadcrumbsJsonLd(breadcrumbs)} />
  <JsonLd data={faqJsonLd(faq)} />
  <JsonLd data={calculatorJsonLd} />
</BaseLayout>

<script>
  const form = document.querySelector('[data-calculator]');
  const result = document.querySelector('[data-result]');
  const error = document.querySelector('[data-error]');
  const recommendations = document.querySelector('[data-recommendations]');

  const roomLabels = {
    bedroom: 'soveværelset',
    basement: 'kælderen',
    living: 'stuen',
    bathroom: 'badeværelset',
  };

  function readData() {
    if (!(form instanceof HTMLFormElement)) return null;
    const formData = new FormData(form);
    const temperature = Number(formData.get('temperature'));
    const humidity = Number(formData.get('humidity'));
    const room = String(formData.get('room'));
    const symptoms = formData.getAll('symptoms').map(String);

    if (!Number.isFinite(temperature) || temperature < 10 || temperature > 32) return null;
    if (!Number.isFinite(humidity) || humidity < 15 || humidity > 95) return null;

    return { temperature, humidity, room, symptoms };
  }

  function calculateDewPoint(temperature, humidity) {
    const a = 17.62;
    const b = 243.12;
    const gamma = Math.log(humidity / 100) + (a * temperature) / (b + temperature);
    return (b * gamma) / (a - gamma);
  }

  function classifyHumidity(data) {
    const { humidity, room, symptoms } = data;
    if (humidity < 35) return 'low';
    if (humidity > 65) return 'high';
    if (humidity > 60 && (room === 'bedroom' || room === 'basement' || symptoms.includes('condensation') || symptoms.includes('mold'))) return 'high';
    if (humidity < 40 && symptoms.includes('dryThroat')) return 'low';
    return 'normal';
  }

  function calculateRisk(data, dewPoint) {
    let score = 0;
    if (data.humidity >= 60) score += 2;
    if (data.humidity >= 70) score += 2;
    if (data.room === 'basement') score += 2;
    if (data.room === 'bathroom') score += 1;
    if (data.room === 'bedroom') score += 1;
    if (data.temperature < 18 && data.humidity >= 55) score += 1;
    if (dewPoint >= data.temperature - 4) score += 2;
    if (data.symptoms.includes('condensation')) score += 2;
    if (data.symptoms.includes('mold')) score += 3;
    if (score >= 6) return 'high';
    if (score >= 3) return 'moderate';
    return 'low';
  }

  function getRecommendations(status, risk, data) {
    const items = [];

    if (status === 'low') {
      items.push('Undgå unødigt høj temperatur, da varm luft om vinteren ofte føles tørrere.');
      items.push('Luft ud kort og effektivt frem for at lade vinduer stå på konstant klem.');
      items.push('Vurder støv, rengøring og ventilation, hvis tør hals eller irritation fortsætter.');
    }

    if (status === 'normal') {
      items.push('Fortsæt med jævn varme og korte, effektive udluftninger.');
      items.push('Mål igen morgen og aften, hvis du oplever tung luft eller dug på ruder.');
    }

    if (status === 'high') {
      items.push('Luft ud med gennemtræk 5-10 minutter og gentag efter bad, madlavning og søvn.');
      items.push('Hold rummet jævnt opvarmet, så kolde overflader ikke samler kondens.');
      items.push('Overvej affugter eller aircondition/varmepumpe med dry mode, hvis fugten bliver ved.');
    }

    if (data.room === 'bathroom') items.push('Brug udsugning under og efter bad, og lad døren stå åben når fugten skal væk.');
    if (data.room === 'basement') items.push('I kældre bør vedvarende fugt undersøges, fordi årsagen kan være konstruktion, kuldebroer eller indtrængende fugt.');
    if (data.symptoms.includes('mold')) items.push('Synlig skimmel bør fjernes korrekt, og fugtkilden bør findes før problemet vender tilbage.');
    if (risk === 'high') items.push('Ved høj skimmel- eller kondensrisiko bør du reagere hurtigt og følge udviklingen med daglige målinger.');

    return [...new Set(items)].slice(0, 5);
  }

  function updateResult() {
    const data = readData();
    if (!data || !result) {
      error?.removeAttribute('hidden');
      return;
    }

    error?.setAttribute('hidden', '');
    const status = classifyHumidity(data);
    const dewPoint = calculateDewPoint(data.temperature, data.humidity);
    const risk = calculateRisk(data, dewPoint);
    const roomLabel = roomLabels[data.room] ?? 'rummet';

    const statusText = {
      low: 'Lav luftfugtighed',
      normal: 'Normal luftfugtighed',
      high: 'Høj luftfugtighed',
    }[status];

    const mainText = {
      low: 'Lav',
      normal: 'Normal',
      high: 'Høj',
    }[status];

    const rangeText = {
      low: `${data.humidity} % relativ luftfugtighed ved ${data.temperature} °C er lavt for ${roomLabel}.`,
      normal: `${data.humidity} % relativ luftfugtighed ved ${data.temperature} °C ligger typisk i komfortområdet.`,
      high: `${data.humidity} % relativ luftfugtighed ved ${data.temperature} °C er højt for ${roomLabel}, især hvis niveauet varer ved.`,
    }[status];

    const riskText = {
      low: `Lav kondensrisiko. Beregnet dugpunkt er ca. ${Math.round(dewPoint)} °C.`,
      moderate: `Moderat risiko for kondens eller skimmel. Beregnet dugpunkt er ca. ${Math.round(dewPoint)} °C.`,
      high: `Høj risiko for kondens eller skimmel, især på kolde overflader. Beregnet dugpunkt er ca. ${Math.round(dewPoint)} °C.`,
    }[risk];

    result.querySelector('[data-status-label]').textContent = statusText;
    result.querySelector('[data-main-result]').textContent = mainText;
    result.querySelector('[data-range-result]').textContent = rangeText;
    result.querySelector('[data-risk-result]').textContent = riskText;
    result.classList.toggle('is-high', status === 'high' || risk === 'high');
    result.classList.toggle('is-low', status === 'low');

    if (recommendations) {
      const items = getRecommendations(status, risk, data);
      recommendations.innerHTML = `<h3>Anbefalinger</h3><ul>${items.map((item) => `<li>${item}</li>`).join('')}</ul>`;
    }
  }

  form?.addEventListener('submit', (event) => {
    event.preventDefault();
    updateResult();
  });

  form?.addEventListener('input', updateResult);
  form?.addEventListener('change', updateResult);
  updateResult();
</script>

<style>
  .calculator-hero { padding: clamp(4rem, 8vw, 7rem) 0 clamp(2.25rem, 5vw, 4rem); }
  .hero-copy { text-align: center; }
  .hero-copy :global(.breadcrumbs) { justify-content: center; }
  .hero-copy h1 { max-width: 1020px; margin: 0.85rem auto 1rem; font-size: clamp(2.65rem, 6vw, 5.35rem); }
  .hero-copy p { max-width: 860px; margin-inline: auto; color: var(--color-muted); font-size: clamp(1.08rem, 2vw, 1.32rem); }
  .hero-actions { display: flex; flex-wrap: wrap; justify-content: center; gap: 0.75rem; margin-top: 1.4rem; }
  .quick-answer { padding: 1.35rem; background: linear-gradient(145deg, rgba(255, 255, 255, 0.96), rgba(220, 251, 255, 0.72)); }
  .hero-copy .quick-answer { max-width: 760px; margin: 2rem auto 0; }
  .quick-answer p { margin: 1rem 0 0; color: var(--color-primary); font-size: 1.12rem; }
  .section-heading { margin-bottom: 1.5rem; }
  .section-heading h2 { margin-top: 0.8rem; }
  .section-heading p { max-width: 760px; color: var(--color-muted); font-size: 1.1rem; }
  .calculator-layout { display: grid; gap: 1.15rem; align-items: start; }
  .calculator-layout.has-sidebar-ad { grid-template-columns: minmax(0, 1fr) minmax(260px, 0.32fr); }
  .calculator-panel { padding: clamp(1.2rem, 3vw, 2rem); }
  .calculator-form { margin-bottom: 1.25rem; }
  .field-grid { display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 1rem; margin-bottom: 1.25rem; }
  label { display: grid; gap: 0.4rem; color: var(--color-primary); font-weight: 800; }
  label span { font-size: 0.95rem; }
