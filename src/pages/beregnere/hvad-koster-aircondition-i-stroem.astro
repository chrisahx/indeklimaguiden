---
import AnswerBox from '../../components/AnswerBox.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import FAQ from '../../components/FAQ.astro';
import GoogleAd from '../../components/GoogleAd.astro';
import JsonLd from '../../components/JsonLd.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { absoluteUrl } from '../../lib/seo';
import { breadcrumbsJsonLd, faqJsonLd } from '../../lib/structured-data';

const path = '/beregnere/hvad-koster-aircondition-i-stroem/';
const sidebarAdSlot = import.meta.env.PUBLIC_ADSENSE_SLOT_CALCULATOR_SIDEBAR;
const wideAdSlot = import.meta.env.PUBLIC_ADSENSE_SLOT_CALCULATOR_WIDE;
const articleAdSlot = import.meta.env.PUBLIC_ADSENSE_SLOT_CALCULATOR_ARTICLE;
const mobileAdSlotOne = import.meta.env.PUBLIC_ADSENSE_SLOT_CALCULATOR_MOBILE_1;
const mobileAdSlotTwo = import.meta.env.PUBLIC_ADSENSE_SLOT_CALCULATOR_MOBILE_2;
const leftRailAdSlot = import.meta.env.PUBLIC_ADSENSE_SLOT_CALCULATOR_LEFT_RAIL;
const rightRailAdSlot = import.meta.env.PUBLIC_ADSENSE_SLOT_CALCULATOR_RIGHT_RAIL;
const showSidebarAd = import.meta.env.DEV || sidebarAdSlot;
const showWideAd = import.meta.env.DEV || wideAdSlot;
const showArticleAd = import.meta.env.DEV || articleAdSlot;
const showMobileAdOne = import.meta.env.DEV || mobileAdSlotOne;
const showMobileAdTwo = import.meta.env.DEV || mobileAdSlotTwo;
const showLeftRailAd = import.meta.env.DEV || leftRailAdSlot;
const showRightRailAd = import.meta.env.DEV || rightRailAdSlot;
const breadcrumbs = [
  { name: 'Forside', url: '/' },
  { name: 'Beregnere', url: '/beregnere/' },
  { name: 'Aircondition strømforbrug', url: path },
];
const faq = [
  {
    question: 'Hvad koster aircondition i strøm?',
    answer:
      'Prisen afhænger af effektforbrug, brugstid og elpris. En aircondition, der bruger 1 kW, koster cirka det samme som elprisen pr. time. Ved 3 kr. pr. kWh koster 1 kW derfor cirka 3 kr. i timen.',
  },
  {
    question: 'Hvor meget strøm bruger en aircondition?',
    answer:
      'Mindre mobile airconditionanlæg bruger ofte omkring 0,7-1,5 kW, mens faste anlæg og luft til luft-varmepumper varierer efter belastning og effektivitet. Se altid produktets oplyste effektforbrug.',
  },
  {
    question: 'Hvordan beregner man strømforbrug for aircondition?',
    answer:
      'Gang effektforbruget i kW med antal timer og derefter med elprisen pr. kWh. Eksempel: 1 kW x 6 timer x 3 kr. = 18 kr. pr. dag.',
  },
  {
    question: 'Hvad betyder SEER for strømforbruget?',
    answer:
      'SEER beskriver sæsoneffektivitet ved køling. Jo højere SEER, desto mere køling får du typisk pr. kWh strøm. Det er især relevant for faste splitanlæg og varmepumper.',
  },
  {
    question: 'Er en luft til luft-varmepumpe billigere i strøm end mobil aircondition?',
    answer:
      'Ofte ja ved samme kølebehov, fordi faste luft til luft-varmepumper typisk har højere effektivitet. Den faktiske pris afhænger dog af model, rumstørrelse, temperaturforskel og brugsmønster.',
  },
];

const calculatorJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  name: 'Hvad koster aircondition i strøm beregner',
  description:
    'Beregn strømforbrug og pris for aircondition ud fra watt eller kW, timer pr. dag, dage pr. måned, elpris og eventuelt SEER.',
  url: absoluteUrl(path),
  applicationCategory: 'CalculatorApplication',
  operatingSystem: 'Web',
  inLanguage: 'da-DK',
  offers: {
    '@type': 'Offer',
    price: '0',
    priceCurrency: 'DKK',
  },
};
---

<BaseLayout
  title="Hvad koster aircondition i strøm? Beregner"
  description="Beregn hvad aircondition koster i strøm. Indtast watt eller kW, timer pr. dag, dage pr. måned og elpris, og få pris pr. dag, måned og sommer."
  path={path}
>
  <section class="calculator-hero">
    <div class="container hero-copy">
      <Breadcrumbs items={breadcrumbs} />
      <span class="pill">Aircondition strømforbrug beregner</span>
      <h1>Hvad koster aircondition i strøm?</h1>
      <p>
        Indtast effektforbrug, brugstid og elpris, og få et hurtigt estimat på hvad din aircondition koster pr. dag, pr. måned og over en hel sommer.
      </p>
      <div class="hero-actions">
        <a class="button" href="#beregner">Brug beregneren</a>
        <a class="button secondary" href="#eksempel">Se eksempel</a>
      </div>
      <aside class="surface quick-answer" aria-label="Kort svar">
        <span class="pill">Kort svar</span>
        <p>
          En aircondition på <strong>1 kW</strong> koster cirka det samme som din elpris pr. time. Ved 3 kr./kWh og 6 timers daglig brug er prisen cirka <strong>18 kr. pr. dag</strong> og <strong>540 kr. pr. måned</strong>.
        </p>
      </aside>
    </div>
  </section>

  <section id="beregner" class="section container calculator-section" aria-labelledby="calculator-heading">
    <div class="section-heading">
      <span class="pill">Strømforbrug beregner</span>
      <h2 id="calculator-heading">Beregn pris for aircondition</h2>
      <p>Resultatet er et vejledende estimat. Den faktiske pris afhænger af elpris, temperatur, rumstørrelse, isolering og hvor hårdt anlægget arbejder.</p>
    </div>

    <div class:list={['calculator-layout', showSidebarAd && 'has-sidebar-ad']}>
      <div class="surface calculator-panel">
        <form class="calculator-form" data-calculator novalidate>
          <div class="field-grid">
            <label>
              <span>Effektforbrug</span>
              <input name="power" type="number" inputmode="decimal" min="0.1" max="10000" step="0.1" value="1" required />
            </label>
            <label>
              <span>Enhed</span>
              <select name="unit">
                <option value="kw" selected>kW</option>
                <option value="w">Watt</option>
              </select>
            </label>
            <label>
              <span>Timer pr. dag</span>
              <input name="hours" type="number" inputmode="decimal" min="0.1" max="24" step="0.5" value="6" required />
            </label>
            <label>
              <span>Dage pr. måned</span>
              <input name="days" type="number" inputmode="numeric" min="1" max="31" step="1" value="30" required />
            </label>
            <label>
              <span>Elpris pr. kWh</span>
              <input name="price" type="number" inputmode="decimal" min="0.1" max="15" step="0.1" value="3" required />
            </label>
            <label>
              <span>Sommerperiode i måneder</span>
              <input name="summerMonths" type="number" inputmode="numeric" min="1" max="6" step="1" value="3" required />
            </label>
            <label class="wide">
              <span class="label-with-help">
                SEER/SCOP, hvis du kender tallet
                <span class="tooltip">
                  <button type="button" class="tooltip-trigger" aria-describedby="seer-scop-help">?</button>
                  <span id="seer-scop-help" class="tooltip-content" role="tooltip">
                    SEER bruges til køling og SCOP til opvarmning. Du finder typisk tallet i produktets datablad, energimærke eller tilbud fra installatøren. Lad feltet stå tomt, hvis du indtaster apparatets faktiske strømforbrug.
                  </span>
                </span>
              </span>
              <input name="seer" type="number" inputmode="decimal" min="1" max="12" step="0.1" placeholder="Valgfrit" />
            </label>
          </div>
          <p class="form-hint">Lad SEER/SCOP stå tomt, hvis du indtaster apparatets faktiske strømforbrug fra mærkaten eller databladet.</p>
          <p class="form-error" data-error hidden>Udfyld venligst realistiske værdier for effektforbrug, timer, dage og elpris.</p>
          <button class="button" type="submit">Beregn strømpris</button>
        </form>

        <aside class="result-card" aria-live="polite" data-result>
          <div>
            <span class="pill">Dit estimat</span>
            <p class="result-kicker" data-usage-label>6 timer dagligt</p>
          </div>
          <div class="result-main">
            <strong data-month-result>Ca. 540 kr./md.</strong>
            <p data-day-result>Det svarer til cirka 18 kr. pr. dag.</p>
          </div>
          <div class="result-details">
            <p data-summer-result>Ca. 1.620 kr. pr. sommer</p>
            <p data-kwh-result>180 kWh pr. måned</p>
          </div>
        </aside>
      </div>

      {showSidebarAd && (
        <aside class="ad-column" aria-label="Annonce">
          <GoogleAd slotId={sidebarAdSlot} className="sidebar-ad" />
        </aside>
      )}
    </div>
  </section>

  {showWideAd && (
    <aside class="container" aria-label="Annonce">
      <GoogleAd slotId={wideAdSlot} className="wide-ad" />
    </aside>
  )}

  <article class:list={['article-shell', (showLeftRailAd || showRightRailAd) && 'has-rail-ads']}>
    {showLeftRailAd && (
      <aside class="rail-ad left-rail" aria-label="Annonce">
        <GoogleAd slotId={leftRailAdSlot} className="rail-ad-unit" />
      </aside>
    )}

    <div class="article-main">
      <aside class="reading side-panel">
        <div class="checklist">
          <h2>Det påvirker prisen</h2>
          <ul>
            <li>Effektforbrug i watt eller kW</li>
            <li>Antal timer pr. dag</li>
            <li>Antal dage pr. måned</li>
            <li>Din faktiske elpris pr. kWh</li>
            <li>Rummets varmebelastning og solindfald</li>
            <li>Anlæggets effektivitet, for eksempel SEER</li>
          </ul>
        </div>
      </aside>

      <div class="reading article-body content-card">
        <AnswerBox>
          Hvad aircondition koster i strøm afhænger især af effektforbrug, antal timer og elpris. Som hurtig tommelfingerregel kan du gange kW med timer og elpris: 1 kW x 6 timer x 3 kr. = 18 kr. pr. dag.
        </AnswerBox>

        {showMobileAdOne && <GoogleAd slotId={mobileAdSlotOne} className="calculator-mobile-ad" />}

        <h2>Hvad koster aircondition i strøm?</h2>
        <p>
          Når du søger efter “hvad koster aircondition i strøm”, er det vigtigste tal anlæggets effektforbrug. Et anlæg, der bruger 1 kW, bruger 1 kWh på en time. Hvis elprisen er 3 kr. pr. kWh, koster den time cirka 3 kr.
        </p>
        <p>
          Derfor bliver prisen hurtigt personlig. To husstande kan have samme aircondition, men få forskellige udgifter, fordi den ene bruger den 2 timer om aftenen, mens den anden køler et varmt rum hele dagen.
        </p>

        <h2>Sådan beregner du aircondition strømforbrug</h2>
        <p>
          Den simple beregning er: effektforbrug i kW x timer pr. dag x elpris pr. kWh. For at finde prisen pr. måned ganger du derefter med antal dage, hvor anlægget er i brug.
        </p>
        <table>
          <thead>
            <tr>
              <th>Eksempel</th>
              <th>Beregning</th>
              <th>Pris ved 3 kr./kWh</th>
            </tr>
          </thead>
          <tbody>
            <tr>
              <td>0,8 kW i 4 timer</td>
              <td>0,8 x 4 = 3,2 kWh</td>
              <td>Ca. 9,60 kr. pr. dag</td>
            </tr>
            <tr>
              <td>1 kW i 6 timer</td>
              <td>1 x 6 = 6 kWh</td>
              <td>Ca. 18 kr. pr. dag</td>
            </tr>
            <tr>
              <td>1,5 kW i 8 timer</td>
              <td>1,5 x 8 = 12 kWh</td>
              <td>Ca. 36 kr. pr. dag</td>
            </tr>
          </tbody>
        </table>

        <h2 id="eksempel">Hvis du bruger aircondition 6 timer dagligt i 30 dage</h2>
        <p>
          Hvis du bruger en aircondition med et strømforbrug på 1 kW i 6 timer dagligt i 30 dage, bruger den cirka 180 kWh på en måned. Ved en elpris på 3 kr. pr. kWh svarer det til cirka 540 kr. pr. måned.
        </p>
        <p>
          Det er netop derfor en beregner er nyttig: en lille ændring i timer, elpris eller effektforbrug kan flytte månedens pris markant.
        </p>

        {showMobileAdTwo && <GoogleAd slotId={mobileAdSlotTwo} className="calculator-mobile-ad" />}

        <h2>Varmepumpe strømforbrug beregner</h2>
        <p>
          En luft til luft-varmepumpe kan også bruges til køling, og her kan strømforbruget være lavere end ved mange mobile airconditionanlæg. Hvis du kender anlæggets faktiske inputeffekt i kW, kan du bruge beregneren direkte.
        </p>
        <p>
          Hvis du kun kender køleydelse og SEER, kan SEER give et mere effektivt estimat. Jo højere SEER, desto mindre strøm skal anlægget typisk bruge for at levere samme køling over en sæson.
        </p>

        {showArticleAd && <GoogleAd slotId={articleAdSlot} className="article-ad" />}

        <h2>Hvad koster det at køle et rum?</h2>
        <p>
          Prisen for at køle et rum afhænger ikke kun af selve airconditionanlægget. Rummets størrelse, solindfald, isolering, vinduer og ønsket temperatur har stor betydning. Et sydvendt rum med store vinduer kræver typisk mere energi end et mindre soveværelse på nordsiden.
        </p>
        <p>
          Vil du reducere strømforbruget, kan du skærme for solen, lukke døre til varme rum, rense filtre og undgå at sætte temperaturen unødigt lavt. Ofte er 24-26 grader nok til at gøre et varmt rum behageligt.
        </p>

        <h2>Sådan sænker du prisen på aircondition</h2>
        <ul>
          <li>Brug solafskærmning før rummet bliver varmt.</li>
          <li>Vælg en moderat temperatur i stedet for maksimal køling.</li>
          <li>Rens filtre, så luftgennemstrømningen ikke bliver dårlig.</li>
          <li>Køl kun de rum, du faktisk opholder dig i.</li>
          <li>Vælg et effektivt anlæg, hvis du bruger køling mange timer hver sommer.</li>
        </ul>
        <p>
          Hvis du stadig er i købsfasen, kan du også bruge vores <a href="/beregnere/aircondition-varmepumpe-stoerrelse/">beregner til aircondition og varmepumpe størrelse</a>, så du ikke vælger en unødigt stor eller for lille model.
        </p>

        <FAQ items={faq} />
      </div>
    </div>

    {showRightRailAd && (
      <aside class="rail-ad right-rail" aria-label="Annonce">
        <GoogleAd slotId={rightRailAdSlot} className="rail-ad-unit" />
      </aside>
    )}
  </article>

  <JsonLd data={breadcrumbsJsonLd(breadcrumbs)} />
  <JsonLd data={faqJsonLd(faq)} />
  <JsonLd data={calculatorJsonLd} />
</BaseLayout>

<script>
  const form = document.querySelector('[data-calculator]');
  const result = document.querySelector('[data-result]');
  const error = document.querySelector('[data-error]');

  const formatKroner = (value) => Math.round(value).toLocaleString('da-DK');
  const formatKwh = (value) => value.toLocaleString('da-DK', { maximumFractionDigits: 1 });
  const formatDecimal = (value) => value.toLocaleString('da-DK', { maximumFractionDigits: 1 });

  function readData() {
    if (!(form instanceof HTMLFormElement)) return null;
    const formData = new FormData(form);
    const power = Number(formData.get('power'));
    const unit = String(formData.get('unit'));
    const hours = Number(formData.get('hours'));
    const days = Number(formData.get('days'));
    const price = Number(formData.get('price'));
    const summerMonths = Number(formData.get('summerMonths'));
    const seerValue = formData.get('seer');
    const seer = seerValue === null || String(seerValue).trim() === '' ? null : Number(seerValue);

    if (!Number.isFinite(power) || power <= 0 || power > 10000) return null;
    if (unit !== 'kw' && unit !== 'w') return null;
    if (!Number.isFinite(hours) || hours <= 0 || hours > 24) return null;
    if (!Number.isFinite(days) || days < 1 || days > 31) return null;
    if (!Number.isFinite(price) || price <= 0 || price > 15) return null;
    if (!Number.isFinite(summerMonths) || summerMonths < 1 || summerMonths > 6) return null;
    if (seer !== null && (!Number.isFinite(seer) || seer < 1 || seer > 12)) return null;

    return { power, unit, hours, days, price, summerMonths, seer };
  }

  function updateResult() {
    const data = readData();
    if (!data || !result) {
      error?.removeAttribute('hidden');
      return;
    }

    error?.setAttribute('hidden', '');

    const enteredKw = data.unit === 'w' ? data.power / 1000 : data.power;
    const effectiveKw = data.seer ? enteredKw / data.seer : enteredKw;
    const kwhDay = effectiveKw * data.hours;
    const kwhMonth = kwhDay * data.days;
    const priceDay = kwhDay * data.price;
    const priceMonth = kwhMonth * data.price;
    const priceSummer = priceMonth * data.summerMonths;

    result.querySelector('[data-usage-label]').textContent = `${formatDecimal(data.hours)} timer dagligt`;
    result.querySelector('[data-month-result]').textContent = `Ca. ${formatKroner(priceMonth)} kr./md.`;
    result.querySelector('[data-day-result]').textContent = `Det svarer til cirka ${formatKroner(priceDay)} kr. pr. dag.`;
    result.querySelector('[data-summer-result]').textContent = `Ca. ${formatKroner(priceSummer)} kr. pr. sommer`;
    result.querySelector('[data-kwh-result]').textContent = `${formatKwh(kwhMonth)} kWh pr. måned`;
  }

  form?.addEventListener('submit', (event) => {
    event.preventDefault();
    updateResult();
  });

  form?.addEventListener('input', updateResult);
  form?.addEventListener('change', updateResult);
  updateResult();
</script>

<style>
  .calculator-hero { padding: clamp(4rem, 8vw, 7rem) 0 clamp(2.25rem, 5vw, 4rem); }
  .hero-copy { text-align: center; }
  .hero-copy :global(.breadcrumbs) { justify-content: center; }
  .hero-copy h1 { max-width: 1020px; margin: 0.85rem auto 1rem; font-size: clamp(2.65rem, 6vw, 5.35rem); }
  .hero-copy p { max-width: 860px; margin-inline: auto; color: var(--color-muted); font-size: clamp(1.08rem, 2vw, 1.32rem); }
  .hero-actions { display: flex; flex-wrap: wrap; justify-content: center; gap: 0.75rem; margin-top: 1.4rem; }
  .quick-answer { padding: 1.35rem; background: linear-gradient(145deg, rgba(255, 255, 255, 0.96), rgba(220, 251, 255, 0.72)); }
  .hero-copy .quick-answer { max-width: 780px; margin: 2rem auto 0; }
  .quick-answer p { margin: 1rem 0 0; color: var(--color-primary); font-size: 1.12rem; }
  .section-heading { margin-bottom: 1.5rem; }
  .section-heading h2 { margin-top: 0.8rem; }
  .section-heading p { max-width: 760px; color: var(--color-muted); font-size: 1.1rem; }
  .calculator-layout { display: grid; gap: 1.15rem; align-items: start; }
  .calculator-layout.has-sidebar-ad { grid-template-columns: minmax(0, 1fr) minmax(260px, 0.32fr); }
  .calculator-panel { padding: clamp(1.2rem, 3vw, 2rem); }
  .calculator-form { margin-bottom: 1.25rem; }
  .field-grid { display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 1rem; margin-bottom: 1rem; }
  label { display: grid; gap: 0.4rem; color: var(--color-primary); font-weight: 800; }
  label span { font-size: 0.95rem; }
  .label-with-help { display: inline-flex; align-items: center; gap: 0.45rem; width: fit-content; }
  .tooltip { position: relative; display: inline-flex; }
  .tooltip-trigger { display: inline-grid; place-items: center; width: 1.25rem; height: 1.25rem; border: 1px solid var(--color-border-strong); border-radius: 999px; background: #fff; color: var(--color-primary); font: inherit; font-size: 0.78rem; font-weight: 900; cursor: help; }
  .tooltip-trigger:focus { outline: 3px solid rgba(32, 199, 215, 0.2); border-color: var(--color-accent-dark); }
  .tooltip-content { position: absolute; left: 50%; bottom: calc(100% + 0.6rem); z-index: 2; width: min(300px, calc(100vw - 3rem)); transform: translateX(-50%); border: 1px solid var(--color-border); border-radius: var(--radius-md); padding: 0.75rem 0.85rem; background: var(--color-primary); color: #fff; box-shadow: 0 14px 32px rgba(6, 25, 35, 0.18); font-size: 0.88rem; font-weight: 650; line-height: 1.45; opacity: 0; pointer-events: none; transition: opacity 0.15s ease, transform 0.15s ease; }
  .tooltip-content::after { content: ''; position: absolute; left: 50%; top: 100%; width: 0.75rem; height: 0.75rem; transform: translate(-50%, -50%) rotate(45deg); background: var(--color-primary); border-right: 1px solid var(--color-border); border-bottom: 1px solid var(--color-border); }
  .tooltip:hover .tooltip-content, .tooltip:focus-within .tooltip-content { opacity: 1; transform: translateX(-50%) translateY(-0.15rem); }
  input, select { width: 100%; border: 1px solid var(--color-border-strong); border-radius: var(--radius-md); padding: 0.85rem 0.9rem; background: #fff; color: var(--color-primary); font: inherit; }
  input:focus, select:focus { outline: 3px solid rgba(32, 199, 215, 0.2); border-color: var(--color-accent-dark); }
  .wide { grid-column: 1 / -1; }
  .form-hint { margin: 0 0 1rem; color: var(--color-muted); font-size: 0.95rem; }
  .form-error { color: #9f1239; font-weight: 800; }
  .result-card { display: grid; grid-template-columns: minmax(160px, 0.4fr) minmax(0, 1fr) minmax(190px, 0.55fr); gap: 1rem; align-items: center; border-radius: var(--radius-lg); padding: clamp(1rem, 2.4vw, 1.4rem); background: linear-gradient(145deg, var(--color-primary), var(--color-primary-soft)); color: #fff; }
  .result-card .pill { border-color: rgba(255, 255, 255, 0.24); background: rgba(255, 255, 255, 0.12); color: #bff8ff; }
  .result-card strong { display: block; margin: 0 0 0.35rem; color: #fff; font-size: clamp(2.1rem, 4.4vw, 3.8rem); line-height: 1; letter-spacing: -0.06em; }
  .result-card p { color: #dbeafe; }
  .result-main p, .result-details p { margin: 0; }
  .result-details { border-left: 1px solid rgba(255, 255, 255, 0.18); padding-left: 1rem; font-weight: 800; }
  .result-details p + p { margin-top: 0.5rem; font-weight: 650; }
  .result-kicker { margin: 0.7rem 0 0; font-weight: 850; text-transform: uppercase; letter-spacing: 0.08em; }
  .ad-column { position: sticky; top: 104px; }
  :global(.sidebar-ad) { min-height: 420px; }
  :global(.wide-ad) { min-height: 92px; margin-bottom: clamp(2rem, 5vw, 4rem); }
  :global(.article-ad) { min-height: 120px; margin: 2.5rem 0; }
  :global(.calculator-mobile-ad) { display: none; min-height: 120px; margin: 2rem 0; }
  .article-shell { padding-bottom: clamp(3rem, 7vw, 6rem); }
  .article-shell.has-rail-ads {
    display: grid;
    grid-template-columns: minmax(140px, 1fr) minmax(0, 800px) minmax(140px, 1fr);
    gap: clamp(1rem, 3vw, 2rem);
