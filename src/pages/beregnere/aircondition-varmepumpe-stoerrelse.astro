---
import AnswerBox from '../../components/AnswerBox.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import FAQ from '../../components/FAQ.astro';
import GoogleAd from '../../components/GoogleAd.astro';
import JsonLd from '../../components/JsonLd.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { absoluteUrl } from '../../lib/seo';
import { breadcrumbsJsonLd, faqJsonLd } from '../../lib/structured-data';

const path = '/beregnere/aircondition-varmepumpe-stoerrelse/';
const sidebarAdSlot = import.meta.env.PUBLIC_ADSENSE_SLOT_CALCULATOR_SIDEBAR;
const wideAdSlot = import.meta.env.PUBLIC_ADSENSE_SLOT_CALCULATOR_WIDE;
const articleAdSlot = import.meta.env.PUBLIC_ADSENSE_SLOT_CALCULATOR_ARTICLE;
const mobileAdSlotOne = import.meta.env.PUBLIC_ADSENSE_SLOT_CALCULATOR_MOBILE_1;
const mobileAdSlotTwo = import.meta.env.PUBLIC_ADSENSE_SLOT_CALCULATOR_MOBILE_2;
const leftRailAdSlot = import.meta.env.PUBLIC_ADSENSE_SLOT_CALCULATOR_LEFT_RAIL;
const rightRailAdSlot = import.meta.env.PUBLIC_ADSENSE_SLOT_CALCULATOR_RIGHT_RAIL;
const showSidebarAd = import.meta.env.DEV || sidebarAdSlot;
const showWideAd = import.meta.env.DEV || wideAdSlot;
const showArticleAd = import.meta.env.DEV || articleAdSlot;
const showMobileAdOne = import.meta.env.DEV || mobileAdSlotOne;
const showMobileAdTwo = import.meta.env.DEV || mobileAdSlotTwo;
const showLeftRailAd = import.meta.env.DEV || leftRailAdSlot;
const showRightRailAd = import.meta.env.DEV || rightRailAdSlot;
const breadcrumbs = [
  { name: 'Forside', url: '/' },
  { name: 'Beregnere', url: '/beregnere/' },
  { name: 'Aircondition og varmepumpe størrelse', url: path },
];
const faq = [
  {
    question: 'Hvor stor varmepumpe skal jeg bruge?',
    answer:
      'Størrelsen afhænger især af rumstørrelse, loftshøjde, isolering, ønsket temperatur og om varmepumpen primært skal bruges til opvarmning, køling eller begge dele. Beregneren giver et groft kW-estimat, men endelig dimensionering bør vurderes af en installatør.',
  },
  {
    question: 'Hvor mange kW skal en varmepumpe være til 50 m²?',
    answer:
      'Et rum på 50 m² kræver ofte omkring 3-5 kW afhængigt af loftshøjde, isolering og varmetab. Dårlig isolering, højt til loftet og store vinduespartier kan øge behovet markant.',
  },
  {
    question: 'Hvordan beregner man størrelsen på aircondition?',
    answer:
      'Man starter typisk med rummets volumen eller areal og justerer for isolering, solindfald, personer og vinduer. Derfor kan to rum på samme antal m² have forskelligt behov for kølekapacitet.',
  },
  {
    question: 'Er det bedre at vælge en for stor varmepumpe?',
    answer:
      'Ikke nødvendigvis. En overdimensioneret varmepumpe kan give dårligere komfort, flere start-stop-cyklusser og unødigt høj pris. En for lille model kan til gengæld have svært ved at holde temperaturen.',
  },
  {
    question: 'Skal jeg bruge samme størrelse til køling og opvarmning?',
    answer:
      'Ikke altid. Kølebehov påvirkes meget af solindfald, vinduer og personer, mens varmebehov især afhænger af isolering, varmetab og udetemperatur. Ved begge behov bør dimensioneringen tage højde for den højeste belastning.',
  },
];

const calculatorJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  name: 'Aircondition og varmepumpe størrelse beregner',
  description:
    'Beregn hvor stor aircondition eller varmepumpe du bør kigge efter ud fra rumstørrelse, loftshøjde, isolering, solindfald, personer og vinduer.',
  url: absoluteUrl(path),
  applicationCategory: 'CalculatorApplication',
  operatingSystem: 'Web',
  inLanguage: 'da-DK',
  offers: {
    '@type': 'Offer',
    price: '0',
    priceCurrency: 'DKK',
  },
};
---

<BaseLayout
  title="Hvor stor aircondition eller varmepumpe skal jeg bruge? Beregner"
  description="Brug vores aircondition og varmepumpe kW beregner. Indtast m², loftshøjde, isolering, solindfald og vinduer, og få et estimat på anbefalet kapacitet."
  path={path}
>
  <section class="calculator-hero">
    <div class="container hero-copy">
        <Breadcrumbs items={breadcrumbs} />
        <span class="pill">Aircondition størrelse beregner</span>
        <h1>Hvor stor aircondition eller varmepumpe skal jeg bruge?</h1>
        <p>
          Indtast rummets størrelse og forhold, og få et praktisk estimat på anbefalet kapacitet i kW. Beregneren kan bruges som første pejlemærke, når du undersøger aircondition eller luft til luft-varmepumpe.
        </p>
        <div class="hero-actions">
          <a class="button" href="#beregner">Brug beregneren</a>
          <a class="button secondary" href="#forklaring">Se beregningsmetode</a>
        </div>
      <aside class="surface quick-answer" aria-label="Kort svar">
        <span class="pill">Kort svar</span>
        <p>
          Mange almindelige rum kræver cirka <strong>2-5 kW</strong>, men behovet ændrer sig med m², loftshøjde, isolering, solindfald og vinduespartier.
        </p>
      </aside>
    </div>
  </section>

  <section id="beregner" class="section container calculator-section" aria-labelledby="calculator-heading">
    <div class="section-heading">
      <span class="pill">Varmepumpe kW beregner</span>
      <h2 id="calculator-heading">Beregn anbefalet kapacitet i kW</h2>
      <p>Resultatet er et vejledende estimat. Det erstatter ikke en konkret dimensionering fra en autoriseret installatør.</p>
    </div>

    <div class:list={['calculator-layout', showSidebarAd && 'has-sidebar-ad']}>
      <div class="surface calculator-panel">
        <form class="calculator-form" data-calculator novalidate>
        <div class="field-grid">
          <label>
            <span>Rumstørrelse i m²</span>
            <input name="area" type="number" inputmode="decimal" min="5" max="250" step="1" value="35" required />
          </label>
          <label>
            <span>Loftshøjde i meter</span>
            <input name="height" type="number" inputmode="decimal" min="2" max="5" step="0.1" value="2.4" required />
          </label>
          <label>
            <span>Isolering</span>
            <select name="insulation">
              <option value="poor">Dårlig</option>
              <option value="average" selected>Middel</option>
              <option value="good">God</option>
            </select>
          </label>
          <label>
            <span>Solindfald</span>
            <select name="sun">
              <option value="low">Lavt</option>
              <option value="normal" selected>Normalt</option>
              <option value="high">Højt</option>
            </select>
          </label>
          <label>
            <span>Antal personer i rummet</span>
            <input name="people" type="number" inputmode="numeric" min="0" max="20" step="1" value="2" required />
          </label>
          <label>
            <span>Store vinduespartier?</span>
            <select name="windows">
              <option value="no" selected>Nej</option>
              <option value="yes">Ja</option>
            </select>
          </label>
          <label class="wide">
            <span>Ønsket brug</span>
            <select name="mode">
              <option value="cooling">Køling</option>
              <option value="heating">Opvarmning</option>
              <option value="both" selected>Begge dele</option>
            </select>
          </label>
        </div>
        <p class="form-error" data-error hidden>Udfyld venligst realistiske værdier for rumstørrelse, loftshøjde og antal personer.</p>
        <button class="button" type="submit">Beregn kapacitet</button>
        </form>

        <aside class="result-card" aria-live="polite" data-result>
          <div>
            <span class="pill">Dit estimat</span>
            <p class="result-kicker" data-mode-label>Begge dele</p>
          </div>
          <div class="result-main">
            <strong data-main-result>Ca. 3,4 kW</strong>
            <p data-range-result>Du bør kigge efter en model omkring 2,9-3,9 kW.</p>
          </div>
          <p class="installer-warning">Endelig dimensionering bør vurderes af installatør.</p>
        </aside>
      </div>

      {showSidebarAd && (
        <aside class="ad-column" aria-label="Annonce">
          <GoogleAd slotId={sidebarAdSlot} className="sidebar-ad" />
        </aside>
      )}
    </div>
  </section>

  {showWideAd && (
    <aside class="container" aria-label="Annonce">
      <GoogleAd slotId={wideAdSlot} className="wide-ad" />
    </aside>
  )}

  <article class:list={['article-shell', (showLeftRailAd || showRightRailAd) && 'has-rail-ads']}>
    {showLeftRailAd && (
      <aside class="rail-ad left-rail" aria-label="Annonce">
        <GoogleAd slotId={leftRailAdSlot} className="rail-ad-unit" />
      </aside>
    )}

    <div class="article-main">
      <aside class="reading side-panel">
        <div class="checklist">
          <h2>Det påvirker kW-behovet</h2>
          <ul>
            <li>Rumstørrelse og loftshøjde</li>
            <li>Isolering og varmetab</li>
            <li>Solindfald og orientering</li>
            <li>Store vinduespartier</li>
            <li>Antal personer i rummet</li>
            <li>Om anlægget skal køle, varme eller begge dele</li>
          </ul>
        </div>
      </aside>

      <div class="reading article-body content-card">
      <AnswerBox>
        En aircondition eller varmepumpe skal dimensioneres efter mere end m² alene. Brug m² som startpunkt, men juster for loftshøjde, isolering, solindfald, vinduer og om anlægget skal køle, varme eller begge dele.
      </AnswerBox>

      {showMobileAdOne && <GoogleAd slotId={mobileAdSlotOne} className="calculator-mobile-ad" />}

      <h2>Hvor stor aircondition skal jeg bruge?</h2>
      <p>
        Når du søger efter en aircondition størrelse beregner, er målet typisk at finde ud af, om et anlæg på for eksempel 2,5 kW, 3,5 kW eller 5 kW passer til rummet. Et lille soveværelse med god isolering kræver langt mindre end en stor stue med højt solindfald og brede vinduespartier.
      </p>
      <p>
        Til køling påvirker solindfald, personer og vinduer resultatet meget. Et sydvendt rum kan derfor have brug for en større model end et nordvendt rum på samme antal m².
      </p>

      <h2>Hvor stor varmepumpe skal jeg bruge?</h2>
      <p>
        Spørgsmålet “hvor stor varmepumpe skal jeg bruge” handler især om varmebehov, isolering og rummets volumen. En luft til luft-varmepumpe skal kunne dække varmetabet på kolde dage, men den bør heller ikke være unødigt stor.
      </p>
      <p>
        En varmepumpe kW beregner kan give et godt indledende estimat, men forhold som planløsning, placering af indedel, kuldebroer og ønsket komforttemperatur bør vurderes konkret.
      </p>

      <h2>Hvor mange kW til m2 varmepumpe?</h2>
      <p>
        Der findes ikke ét fast tal for hvor mange kW til m2 varmepumpe, fordi to boliger på samme størrelse kan have meget forskelligt varmetab. Som grov tommelfingerregel vil større rum, dårligere isolering og højere loftshøjde øge kW-behovet.
      </p>
      <table>
        <thead>
          <tr>
            <th>Rumtype</th>
            <th>Typisk forhold</th>
            <th>Hvad betyder det?</th>
          </tr>
        </thead>
        <tbody>
          <tr>
            <td>Soveværelse</td>
            <td>Mindre areal, ofte lavere varmebelastning</td>
            <td>Ofte lavere kapacitet, men støjniveau er ekstra vigtigt.</td>
          </tr>
          <tr>
            <td>Stue/alrum</td>
            <td>Større areal, flere personer og vinduer</td>
            <td>Kræver ofte mere kapacitet og god luftfordeling.</td>
          </tr>
          <tr>
            <td>Sommerhus</td>
            <td>Varierende isolering og hurtig opvarmning</td>
            <td>Installatørens vurdering er særlig vigtig.</td>
          </tr>
        </tbody>
      </table>

      <h2 id="forklaring">Sådan beregner vi estimatet</h2>
      <p>
        Beregneren starter med rummets volumen ud fra m² og loftshøjde. Derefter justeres estimatet for isolering, solindfald, store vinduespartier og antal personer. Ved opvarmning vægter isolering og rumvolumen højt. Ved køling vægter sol, vinduer og personer mere.
      </p>
      <p>
        Hvis du vælger “begge dele”, viser beregneren den højeste relevante belastning. Derfor kan resultatet blive højere end ved kun køling eller kun opvarmning.
      </p>

      {showMobileAdTwo && <GoogleAd slotId={mobileAdSlotTwo} className="calculator-mobile-ad" />}

      {showArticleAd && <GoogleAd slotId={articleAdSlot} className="article-ad" />}

      <h2>Hvornår bør en installatør dimensionere anlægget?</h2>
      <p>
        Du bør få en installatør til at vurdere dimensioneringen, hvis rummet har meget store vinduer, dårlig isolering, åben planløsning, flere sammenhængende rum, usædvanligt højt til loftet eller hvis varmepumpen skal være primær varmekilde.
      </p>
      <p>
        Læs også vores guides om <a href="/aircondition/">aircondition</a>, <a href="/varmepumper/">varmepumper</a> og <a href="/varmepumper/luft-til-luft-varmepumpe-pris/">pris på luft til luft-varmepumpe</a>.
      </p>

      <FAQ items={faq} />
      </div>
    </div>

    {showRightRailAd && (
      <aside class="rail-ad right-rail" aria-label="Annonce">
        <GoogleAd slotId={rightRailAdSlot} className="rail-ad-unit" />
      </aside>
    )}
  </article>

  <JsonLd data={breadcrumbsJsonLd(breadcrumbs)} />
  <JsonLd data={faqJsonLd(faq)} />
  <JsonLd data={calculatorJsonLd} />
</BaseLayout>

<script>
  const form = document.querySelector('[data-calculator]');
  const result = document.querySelector('[data-result]');
  const error = document.querySelector('[data-error]');

  const modeLabels = {
    cooling: 'Køling',
    heating: 'Opvarmning',
    both: 'Begge dele',
  };

  const roundKw = (value) => Math.round(value * 10) / 10;
  const formatKw = (value) => roundKw(value).toLocaleString('da-DK', { minimumFractionDigits: 1, maximumFractionDigits: 1 });

  function calculateCapacity(data) {
    const volume = data.area * data.height;
    const insulationCooling = { poor: 1.18, average: 1, good: 0.88 }[data.insulation];
    const insulationHeating = { poor: 1.35, average: 1.08, good: 0.9 }[data.insulation];
    const sunFactor = { low: 0.9, normal: 1, high: 1.18 }[data.sun];
    const windowFactor = data.windows === 'yes' ? 1.16 : 1;

    const coolingKw = volume * 0.038 * insulationCooling * sunFactor * windowFactor + data.people * 0.12;
    const heatingKw = volume * 0.043 * insulationHeating * (data.windows === 'yes' ? 1.08 : 1);

    if (data.mode === 'cooling') return coolingKw;
    if (data.mode === 'heating') return heatingKw;
    return Math.max(coolingKw, heatingKw);
  }

  function readData() {
    if (!(form instanceof HTMLFormElement)) return null;
    const formData = new FormData(form);
    const area = Number(formData.get('area'));
    const height = Number(formData.get('height'));
    const people = Number(formData.get('people'));
    const insulation = String(formData.get('insulation'));
    const sun = String(formData.get('sun'));
    const windows = String(formData.get('windows'));
    const mode = String(formData.get('mode'));

    if (!Number.isFinite(area) || area < 5 || area > 250) return null;
    if (!Number.isFinite(height) || height < 2 || height > 5) return null;
    if (!Number.isFinite(people) || people < 0 || people > 20) return null;

    return { area, height, people, insulation, sun, windows, mode };
  }

  function updateResult() {
    const data = readData();
    if (!data || !result) {
      error?.removeAttribute('hidden');
      return;
    }

    error?.setAttribute('hidden', '');
    const capacity = Math.max(calculateCapacity(data), 1.5);
    const low = Math.max(roundKw(capacity * 0.85), 1.5);
    const high = roundKw(capacity * 1.15);

    result.querySelector('[data-mode-label]').textContent = modeLabels[data.mode] ?? 'Estimat';
    result.querySelector('[data-main-result]').textContent = `Ca. ${formatKw(capacity)} kW`;
    result.querySelector('[data-range-result]').textContent = `Du bør kigge efter en model omkring ${formatKw(low)}-${formatKw(high)} kW.`;
  }

  form?.addEventListener('submit', (event) => {
    event.preventDefault();
    updateResult();
  });

  form?.addEventListener('input', updateResult);
  form?.addEventListener('change', updateResult);
  updateResult();
</script>

<style>
  .calculator-hero { padding: clamp(4rem, 8vw, 7rem) 0 clamp(2.25rem, 5vw, 4rem); }
  .hero-copy { text-align: center; }
  .hero-copy :global(.breadcrumbs) { justify-content: center; }
  .hero-copy h1 { max-width: 1020px; margin: 0.85rem auto 1rem; font-size: clamp(2.65rem, 6vw, 5.35rem); }
  .hero-copy p { max-width: 860px; margin-inline: auto; color: var(--color-muted); font-size: clamp(1.08rem, 2vw, 1.32rem); }
  .hero-actions { display: flex; flex-wrap: wrap; justify-content: center; gap: 0.75rem; margin-top: 1.4rem; }
  .quick-answer { padding: 1.35rem; background: linear-gradient(145deg, rgba(255, 255, 255, 0.96), rgba(220, 251, 255, 0.72)); }
  .hero-copy .quick-answer { max-width: 760px; margin: 2rem auto 0; }
  .quick-answer p { margin: 1rem 0 0; color: var(--color-primary); font-size: 1.12rem; }
  .section-heading { margin-bottom: 1.5rem; }
  .section-heading h2 { margin-top: 0.8rem; }
  .section-heading p { max-width: 760px; color: var(--color-muted); font-size: 1.1rem; }
  .calculator-layout { display: grid; gap: 1.15rem; align-items: start; }
  .calculator-layout.has-sidebar-ad { grid-template-columns: minmax(0, 1fr) minmax(260px, 0.32fr); }
  .calculator-panel { padding: clamp(1.2rem, 3vw, 2rem); }
  .calculator-form { margin-bottom: 1.25rem; }
  .field-grid { display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 1rem; margin-bottom: 1.25rem; }
  label { display: grid; gap: 0.4rem; color: var(--color-primary); font-weight: 800; }
  label span { font-size: 0.95rem; }
  input, select { width: 100%; border: 1px solid var(--color-border-strong); border-radius: var(--radius-md); padding: 0.85rem 0.9rem; background: #fff; color: var(--color-primary); font: inherit; }
  input:focus, select:focus { outline: 3px solid rgba(32, 199, 215, 0.2); border-color: var(--color-accent-dark); }
  .wide { grid-column: 1 / -1; }
  .form-error { color: #9f1239; font-weight: 800; }
  .result-card { display: grid; grid-template-columns: minmax(160px, 0.4fr) minmax(0, 1fr) minmax(190px, 0.55fr); gap: 1rem; align-items: center; border-radius: var(--radius-lg); padding: clamp(1rem, 2.4vw, 1.4rem); background: linear-gradient(145deg, var(--color-primary), var(--color-primary-soft)); color: #fff; }
  .result-card .pill { border-color: rgba(255, 255, 255, 0.24); background: rgba(255, 255, 255, 0.12); color: #bff8ff; }
  .result-card strong { display: block; margin: 0 0 0.35rem; color: #fff; font-size: clamp(2.25rem, 5vw, 4.15rem); line-height: 1; letter-spacing: -0.06em; }
  .result-card p { color: #dbeafe; }
  .result-main p { margin: 0; }
  .result-kicker { margin: 0.7rem 0 0; font-weight: 850; text-transform: uppercase; letter-spacing: 0.08em; }
  .installer-warning { border-left: 1px solid rgba(255, 255, 255, 0.18); margin: 0; padding-left: 1rem; font-weight: 800; }
  .ad-column { position: sticky; top: 104px; }
  :global(.sidebar-ad) { min-height: 420px; }
  :global(.wide-ad) { min-height: 92px; margin-bottom: clamp(2rem, 5vw, 4rem); }
  :global(.article-ad) { min-height: 120px; margin: 2.5rem 0; }
  :global(.calculator-mobile-ad) { display: none; min-height: 120px; margin: 2rem 0; }
  .article-shell { width: min(800px, calc(100% - 40px)); margin-inline: auto; padding-bottom: clamp(3rem, 7vw, 6rem); }
  .article-shell.has-rail-ads {
    display: grid;
    grid-template-columns: minmax(140px, 1fr) minmax(0, 800px) minmax(140px, 1fr);
    gap: clamp(1rem, 3vw, 2rem);
    width: min(1420px, calc(100% - 40px));
    margin-inline: auto;
    align-items: start;
  }
  .article-main { min-width: 0; }
  .article-shell:not(.has-rail-ads) .reading { width: 100%; margin-inline: 0; }
  .article-shell.has-rail-ads .reading { width: 100%; }
  .rail-ad { position: sticky; top: 104px; min-width: 0; }
  :global(.rail-ad-unit) { min-height: 600px; }
  .left-rail { grid-column: 1; }
  .article-main { grid-column: 2; }
  .right-rail { grid-column: 3; }
  .content-card {
    padding: clamp(1.35rem, 4vw, 2.75rem);
    background: #fff;
    border: 1px solid rgba(217, 229, 232, 0.7);
    border-radius: var(--radius-xl);
    box-shadow: 0 1px 2px rgba(6, 25, 35, 0.025);
  }
  .side-panel { margin: 0 0 1.25rem; }
  .checklist { border: 1px solid var(--color-border); border-radius: var(--radius-lg); padding: clamp(1.1rem, 3vw, 1.5rem); background: rgba(255, 255, 255, 0.7); }
  .checklist h2 { margin-top: 0; font-size: 1.35rem; }
  .checklist ul { margin: 0; padding-left: 1.25rem; color: var(--color-muted); }
  .checklist li + li { margin-top: 0.55rem; }

  @media (max-width: 920px) {
    .calculator-layout.has-sidebar-ad { grid-template-columns: 1fr; }
    .ad-column { position: static; }
    :global(.sidebar-ad) { min-height: 120px; }
    .result-card { grid-template-columns: 1fr; }
    .installer-warning { border-top: 1px solid rgba(255, 255, 255, 0.18); border-left: 0; padding: 1rem 0 0; }
    .article-shell.has-rail-ads { display: block; width: auto; }
    .rail-ad { display: none; }
    :global(.calculator-mobile-ad) { display: block; }
  }

  @media (max-width: 620px) {
    .field-grid { grid-template-columns: 1fr; }
  }
</style>
