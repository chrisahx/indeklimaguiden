---
import AnswerBox from '../../components/AnswerBox.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import FAQ from '../../components/FAQ.astro';
import GoogleAd from '../../components/GoogleAd.astro';
import JsonLd from '../../components/JsonLd.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { absoluteUrl } from '../../lib/seo';
import { breadcrumbsJsonLd, faqJsonLd } from '../../lib/structured-data';

const path = '/beregnere/varmepumpe-vs-elradiator/';
const sidebarAdSlot = import.meta.env.PUBLIC_ADSENSE_SLOT_CALCULATOR_SIDEBAR;
const wideAdSlot = import.meta.env.PUBLIC_ADSENSE_SLOT_CALCULATOR_WIDE;
const articleAdSlot = import.meta.env.PUBLIC_ADSENSE_SLOT_CALCULATOR_ARTICLE;
const mobileAdSlotOne = import.meta.env.PUBLIC_ADSENSE_SLOT_CALCULATOR_MOBILE_1;
const mobileAdSlotTwo = import.meta.env.PUBLIC_ADSENSE_SLOT_CALCULATOR_MOBILE_2;
const leftRailAdSlot = import.meta.env.PUBLIC_ADSENSE_SLOT_CALCULATOR_LEFT_RAIL;
const rightRailAdSlot = import.meta.env.PUBLIC_ADSENSE_SLOT_CALCULATOR_RIGHT_RAIL;
const showSidebarAd = import.meta.env.DEV || sidebarAdSlot;
const showWideAd = import.meta.env.DEV || wideAdSlot;
const showArticleAd = import.meta.env.DEV || articleAdSlot;
const showMobileAdOne = import.meta.env.DEV || mobileAdSlotOne;
const showMobileAdTwo = import.meta.env.DEV || mobileAdSlotTwo;
const showLeftRailAd = import.meta.env.DEV || leftRailAdSlot;
const showRightRailAd = import.meta.env.DEV || rightRailAdSlot;
const breadcrumbs = [
  { name: 'Forside', url: '/' },
  { name: 'Beregnere', url: '/beregnere/' },
  { name: 'Varmepumpe vs elradiator', url: path },
];
const faq = [
  {
    question: 'Hvor meget kan man spare ved at skifte fra elradiator til varmepumpe?',
    answer:
      'Besparelsen afhænger af dit nuværende elforbrug til varme, elpris og varmepumpens SCOP. Med en SCOP på 4 kan varmepumpen teoretisk levere samme varme med cirka en fjerdedel af strømforbruget fra direkte elvarme.',
  },
  {
    question: 'Er en luft til luft-varmepumpe billigere end elradiator?',
    answer:
      'Ja, i drift er en luft til luft-varmepumpe normalt billigere end elradiatorer, fordi den flytter varme i stedet for kun at omdanne strøm direkte til varme. Økonomien afhænger dog af installationspris, placering, varmebehov og faktisk brug.',
  },
  {
    question: 'Hvad betyder SCOP i beregneren?',
    answer:
      'SCOP er varmepumpens sæsonvirkningsgrad for opvarmning. En SCOP på 4 betyder, at varmepumpen over sæsonen typisk leverer omkring 4 kWh varme for hver 1 kWh strøm.',
  },
  {
    question: 'Kan varmepumpen erstatte alle elradiatorer?',
    answer:
      'Ikke altid. En luft til luft-varmepumpe varmer bedst de rum, hvor luften kan cirkulere fra indedelen. Elradiatorer kan stadig være nødvendige i lukkede værelser, badeværelser eller som backup på kolde dage.',
  },
  {
    question: 'Hvor finder jeg mit elforbrug til varme?',
    answer:
      'Du kan ofte finde samlet elforbrug hos dit elselskab eller på eloverblik.dk. Hvis boligen kun bruger el til varme, kan du estimere varmeandelen ved at trække almindeligt husholdningsforbrug fra det samlede årsforbrug.',
  },
];

const calculatorJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  name: 'Varmepumpe vs elradiator beregner',
  description:
    'Beregn besparelse, tilbagebetalingstid og årlig strømreduktion ved at skifte fra elradiatorer til luft til luft-varmepumpe.',
  url: absoluteUrl(path),
  applicationCategory: 'CalculatorApplication',
  operatingSystem: 'Web',
  inLanguage: 'da-DK',
  offers: {
    '@type': 'Offer',
    price: '0',
    priceCurrency: 'DKK',
  },
};
---

<BaseLayout
  title="Varmepumpe vs elradiator beregner | Beregn besparelse"
  description="Beregn hvor meget billigere en luft til luft-varmepumpe kan være end elradiatorer. Se besparelse, strømreduktion og tilbagebetalingstid."
  path={path}
>
  <section class="calculator-hero">
    <div class="container hero-copy">
      <Breadcrumbs items={breadcrumbs} />
      <span class="pill">Varmepumpe vs elradiator beregner</span>
      <h1>Varmepumpe vs elradiator: beregn din besparelse</h1>
      <p>
        Indtast antal elradiatorer, årligt elforbrug til varme, elpris, forventet SCOP og pris på varmepumpe inkl. installation. Beregneren viser estimeret besparelse, tilbagebetalingstid og hvor meget strøm du kan reducere.
      </p>
      <div class="hero-actions">
        <a class="button" href="#beregner">Brug beregneren</a>
        <a class="button secondary" href="#forklaring">Se beregningsmetode</a>
      </div>
      <aside class="surface quick-answer" aria-label="Kort svar">
        <span class="pill">Kort svar</span>
        <p>
          En luft til luft-varmepumpe er ofte markant billigere i drift end elradiatorer. Ved <strong>SCOP 4</strong> kan strømforbruget til samme varmebehov groft falde med omkring <strong>75%</strong>.
        </p>
      </aside>
    </div>
  </section>

  <section id="beregner" class="section container calculator-section" aria-labelledby="calculator-heading">
    <div class="section-heading">
      <span class="pill">Elvarme til varmepumpe besparelse</span>
      <h2 id="calculator-heading">Beregn om varmepumpe er billigere end elradiator</h2>
      <p>Resultatet er vejledende og forudsætter, at varmepumpen kan levere samme varmemængde som det angivne elforbrug. Få altid en installatør til at vurdere placering og dækning.</p>
    </div>

    <div class:list={['calculator-layout', showSidebarAd && 'has-sidebar-ad']}>
      <div class="surface calculator-panel">
        <form class="calculator-form" data-calculator novalidate>
          <div class="field-grid">
            <label>
              <span>Antal elradiatorer</span>
              <input name="radiators" type="number" inputmode="numeric" min="1" max="40" step="1" value="6" required />
            </label>
            <label>
              <span class="label-with-help">
                Årligt elforbrug til varme i kWh
                <span class="tooltip">
                  <button type="button" class="tooltip-trigger" aria-describedby="heat-usage-help">?</button>
                  <span id="heat-usage-help" class="tooltip-content" role="tooltip">
                    Find årsforbruget hos dit elselskab eller på eloverblik.dk. Hvis du kun kender samlet elforbrug, så fratræk typisk husholdningsforbrug før du indtaster varmeforbruget.
                  </span>
                </span>
              </span>
              <input name="annualHeatKwh" type="number" inputmode="decimal" min="500" max="80000" step="100" value="12000" required />
            </label>
            <label>
              <span class="label-with-help">
                Elpris pr. kWh
                <span class="tooltip">
                  <button type="button" class="tooltip-trigger" aria-describedby="electricity-price-help">?</button>
                  <span id="electricity-price-help" class="tooltip-content" role="tooltip">
                    Brug din gennemsnitlige pris inkl. afgifter, transport og moms. Du kan ofte se gennemsnitspris på elregningen eller hos dit elselskab.
                  </span>
                </span>
              </span>
              <input name="electricityPrice" type="number" inputmode="decimal" min="0.5" max="15" step="0.1" value="2.8" required />
            </label>
            <label>
              <span class="label-with-help">
                Forventet SCOP
                <span class="tooltip">
                  <button type="button" class="tooltip-trigger" aria-describedby="scop-help">?</button>
                  <span id="scop-help" class="tooltip-content" role="tooltip">
                    SCOP står typisk i produktets datablad, energimærke eller tilbud fra installatøren. Kender du ikke tallet, kan 3,5-4,5 bruges som groft udgangspunkt for mange luft til luft-varmepumper.
                  </span>
                </span>
              </span>
              <input name="scop" type="number" inputmode="decimal" min="1.5" max="7" step="0.1" value="4.0" required />
            </label>
            <label class="wide">
              <span class="label-with-help">
                Pris på varmepumpe inkl. installation
                <span class="tooltip">
                  <button type="button" class="tooltip-trigger" aria-describedby="pump-price-help">?</button>
                  <span id="pump-price-help" class="tooltip-content" role="tooltip">
                    Brug den samlede pris fra tilbuddet inkl. indedel, udedel, standardmontering, materialer og moms. Ekstra elarbejde eller lang rørføring kan ændre prisen.
                  </span>
                </span>
              </span>
              <input name="pumpPrice" type="number" inputmode="decimal" min="5000" max="150000" step="500" value="25000" required />
            </label>
          </div>
          <p class="form-hint">Beregneren sammenligner direkte elvarme med varmepumpe. Elradiatorer regnes som 1 kWh strøm til cirka 1 kWh varme.</p>
          <p class="form-error" data-error hidden>Udfyld venligst realistiske værdier for elradiatorer, varmeforbrug, elpris, SCOP og installationspris.</p>
          <button class="button" type="submit">Beregn besparelse</button>
        </form>

        <aside class="result-card" aria-live="polite" data-result>
          <div>
            <span class="pill">Dit estimat</span>
            <p class="result-kicker" data-radiator-result>6 elradiatorer</p>
          </div>
          <div class="result-main">
            <strong data-saving-result>Ca. 25.200 kr./år</strong>
            <p data-payback-result>Tilbagebetalingstid: ca. 1,0 år.</p>
          </div>
          <div class="result-details">
            <p data-reduction-result>Årlig strømreduktion: ca. 9.000 kWh</p>
            <p data-cheaper-result>Varmepumpe er ca. 75% billigere i drift.</p>
          </div>
        </aside>
      </div>

      {showSidebarAd && (
        <aside class="ad-column" aria-label="Annonce">
          <GoogleAd slotId={sidebarAdSlot} className="sidebar-ad" />
        </aside>
      )}
    </div>
  </section>

  {showWideAd && (
    <aside class="container" aria-label="Annonce">
      <GoogleAd slotId={wideAdSlot} className="wide-ad" />
    </aside>
  )}

  <article class:list={['article-shell', (showLeftRailAd || showRightRailAd) && 'has-rail-ads']}>
    {showLeftRailAd && (
      <aside class="rail-ad left-rail" aria-label="Annonce">
        <GoogleAd slotId={leftRailAdSlot} className="rail-ad-unit" />
      </aside>
    )}

    <div class="article-main">
      <aside class="reading side-panel">
        <div class="checklist">
          <h2>Det styrer besparelsen</h2>
          <ul>
            <li>Årligt elforbrug til varme</li>
            <li>Din reelle elpris pr. kWh</li>
            <li>Varmepumpens SCOP i praksis</li>
            <li>Pris inkl. installation</li>
            <li>Om varmepumpen kan dække alle rum</li>
            <li>Placering af indedel og luftcirkulation</li>
          </ul>
        </div>
      </aside>

      <div class="reading article-body content-card">
        <AnswerBox>
          Varmepumpe er normalt billigere end elradiator, fordi direkte elvarme bruger cirka 1 kWh strøm pr. kWh varme, mens en luft til luft-varmepumpe ofte leverer flere kWh varme pr. kWh strøm. Den konkrete besparelse afhænger især af elforbrug, elpris, SCOP og installationspris.
        </AnswerBox>

        {showMobileAdOne && <GoogleAd slotId={mobileAdSlotOne} className="calculator-mobile-ad" />}

        <h2>Varmepumpe vs elradiator: hvad er billigst?</h2>
        <p>
          Når man sammenligner varmepumpe vs elradiator, er forskellen først og fremmest effektiviteten. En elradiator er direkte elvarme: 1 kWh strøm bliver omtrent til 1 kWh varme. En luft til luft-varmepumpe flytter varme ind i boligen og kan derfor levere flere kWh varme for hver kWh strøm.
        </p>
        <p>
          Derfor kan søgninger som “spare penge varmepumpe elvarme”, “elvarme til varmepumpe besparelse” og “luft til luft varmepumpe besparelse” ofte handle om samme regnestykke: hvor meget af dit nuværende varmeforbrug kan en varmepumpe dække, og hvor effektivt gør den det over en hel fyringssæson?
        </p>

        <h2>Så meget billigere er varmepumpe end elradiator</h2>
        <p>
          Hvis dit varmebehov er 12.000 kWh om året, bruger elradiatorer cirka 12.000 kWh strøm. En varmepumpe med SCOP 4 bruger i samme simple regnestykke cirka 3.000 kWh strøm. Det giver en strømreduktion på 9.000 kWh, før man medregner installationspris og eventuelle rum, som stadig kræver supplerende elvarme.
        </p>
        <table>
          <thead>
            <tr>
              <th>SCOP</th>
              <th>Strømforbrug ved 12.000 kWh varme</th>
              <th>Reduktion mod elradiator</th>
            </tr>
          </thead>
          <tbody>
            <tr>
              <td>3,0</td>
              <td>Ca. 4.000 kWh</td>
              <td>Ca. 67%</td>
            </tr>
            <tr>
              <td>4,0</td>
              <td>Ca. 3.000 kWh</td>
              <td>Ca. 75%</td>
            </tr>
            <tr>
              <td>5,0</td>
              <td>Ca. 2.400 kWh</td>
              <td>Ca. 80%</td>
            </tr>
          </tbody>
        </table>

        <h2 id="forklaring">Sådan beregner vi besparelse og tilbagebetalingstid</h2>
        <p>
          Beregneren bruger dit årlige elforbrug til varme som varmebehov. Elradiatorer antages at levere cirka samme antal kWh varme som de bruger i strøm. Varmepumpens forventede strømforbrug beregnes ved at dividere varmebehovet med SCOP.
        </p>
        <p>
          Årlig besparelse beregnes som forskellen mellem nuværende eludgift til elradiatorer og den estimerede eludgift til varmepumpen. Tilbagebetalingstid beregnes ved at dividere prisen på varmepumpen inkl. installation med den årlige besparelse.
        </p>

        {showMobileAdTwo && <GoogleAd slotId={mobileAdSlotTwo} className="calculator-mobile-ad" />}

        {showArticleAd && <GoogleAd slotId={articleAdSlot} className="article-ad" />}

        <h2>Hvornår er besparelsen størst?</h2>
        <p>
          Besparelsen er typisk størst i boliger, sommerhuse og tilbygninger med højt elforbrug til opvarmning. Jo flere kWh du i dag bruger på elvarme, desto større bliver værdien af at reducere strømforbruget med en varmepumpe. Elprisen betyder også meget: en højere elpris gør hver sparet kWh mere værd.
        </p>

        <h2>Kan en luft til luft-varmepumpe erstatte elradiatorer?</h2>
        <p>
          En luft til luft-varmepumpe kan ofte dække en stor del af opvarmningen i åbne opholdsrum, men den erstatter ikke nødvendigvis alle elradiatorer i praksis. Lukkede værelser, badeværelser, lange gangforløb og dårlig luftcirkulation kan betyde, at nogle elradiatorer stadig bruges som supplement.
        </p>
        <p>
          Derfor bør beregnerens resultat ses som et potentiale for “elvarme til varmepumpe besparelse”. Et konkret tilbud bør samtidig vurdere placering af indedel, støj, kapacitet, elinstallation og hvor stor del af boligen varmepumpen realistisk kan opvarme.
        </p>

        <h2>Energistyrelsens perspektiv på varmepumper</h2>
        <p>
          Luft til luft-varmepumper har et dokumenteret energisparepotentiale, og Energistyrelsens materiale peger på, at korrekt installation, placering og brug har stor betydning for den faktiske besparelse. Det er især relevant, når alternativet er direkte elvarme fra elradiatorer.
        </p>
        <p>
          Læs også vores guides om <a href="/varmepumper/">varmepumper</a>, <a href="/varmepumper/luft-til-luft-varmepumpe-pris/">pris på luft til luft-varmepumpe</a>, <a href="/beregnere/kan-varmepumpe-betale-sig/">om en varmepumpe kan betale sig</a> og <a href="/beregnere/aircondition-varmepumpe-stoerrelse/">hvor stor varmepumpe du skal bruge</a>.
        </p>

        <FAQ items={faq} />
      </div>
    </div>

    {showRightRailAd && (
      <aside class="rail-ad right-rail" aria-label="Annonce">
        <GoogleAd slotId={rightRailAdSlot} className="rail-ad-unit" />
      </aside>
    )}
  </article>

  <JsonLd data={breadcrumbsJsonLd(breadcrumbs)} />
  <JsonLd data={faqJsonLd(faq)} />
  <JsonLd data={calculatorJsonLd} />
</BaseLayout>

<script>
  const form = document.querySelector('[data-calculator]');
  const result = document.querySelector('[data-result]');
  const error = document.querySelector('[data-error]');

  const formatKr = (value) => Math.round(value).toLocaleString('da-DK');
  const formatNumber = (value) => Math.round(value).toLocaleString('da-DK');
  const formatYears = (value) => value.toLocaleString('da-DK', { minimumFractionDigits: 1, maximumFractionDigits: 1 });
  const formatPercent = (value) => Math.round(value).toLocaleString('da-DK');

  function readData() {
    if (!(form instanceof HTMLFormElement)) return null;
    const formData = new FormData(form);
    const radiators = Number(formData.get('radiators'));
    const annualHeatKwh = Number(formData.get('annualHeatKwh'));
    const electricityPrice = Number(formData.get('electricityPrice'));
    const scop = Number(formData.get('scop'));
    const pumpPrice = Number(formData.get('pumpPrice'));

    if (!Number.isFinite(radiators) || radiators < 1 || radiators > 40) return null;
    if (!Number.isFinite(annualHeatKwh) || annualHeatKwh < 500 || annualHeatKwh > 80000) return null;
    if (!Number.isFinite(electricityPrice) || electricityPrice < 0.5 || electricityPrice > 15) return null;
    if (!Number.isFinite(scop) || scop < 1.5 || scop > 7) return null;
    if (!Number.isFinite(pumpPrice) || pumpPrice < 5000 || pumpPrice > 150000) return null;

    return { radiators, annualHeatKwh, electricityPrice, scop, pumpPrice };
  }

  function calculate(data) {
    const currentAnnualCost = data.annualHeatKwh * data.electricityPrice;
    const pumpElectricityKwh = data.annualHeatKwh / data.scop;
    const pumpAnnualCost = pumpElectricityKwh * data.electricityPrice;
    const annualSaving = currentAnnualCost - pumpAnnualCost;
    const electricityReduction = data.annualHeatKwh - pumpElectricityKwh;
    const cheaperPercent = currentAnnualCost > 0 ? (annualSaving / currentAnnualCost) * 100 : 0;
    const payback = annualSaving > 0 ? data.pumpPrice / annualSaving : null;

    return { annualSaving, electricityReduction, cheaperPercent, payback };
  }

  function updateResult() {
    const data = readData();
    if (!data || !result) {
      error?.removeAttribute('hidden');
      return;
    }

    error?.setAttribute('hidden', '');
    const estimate = calculate(data);
    const paybackText = estimate.payback
      ? `Tilbagebetalingstid: ca. ${formatYears(estimate.payback)} år.`
      : 'Tilbagebetalingstid: ikke positiv med de valgte tal.';

    result.querySelector('[data-radiator-result]').textContent = `${formatNumber(data.radiators)} elradiator${data.radiators === 1 ? '' : 'er'}`;
    result.querySelector('[data-saving-result]').textContent = estimate.annualSaving > 0
      ? `Ca. ${formatKr(estimate.annualSaving)} kr./år`
      : 'Ingen estimeret besparelse';
    result.querySelector('[data-payback-result]').textContent = paybackText;
    result.querySelector('[data-reduction-result]').textContent = `Årlig strømreduktion: ca. ${formatNumber(estimate.electricityReduction)} kWh`;
    result.querySelector('[data-cheaper-result]').textContent = `Varmepumpe er ca. ${formatPercent(estimate.cheaperPercent)}% billigere i drift.`;
  }

  form?.addEventListener('submit', (event) => {
    event.preventDefault();
    updateResult();
  });

  form?.addEventListener('input', updateResult);
  form?.addEventListener('change', updateResult);
  updateResult();
</script>

<style>
  .calculator-hero { padding: clamp(4rem, 8vw, 7rem) 0 clamp(2.25rem, 5vw, 4rem); }
  .hero-copy { text-align: center; }
  .hero-copy :global(.breadcrumbs) { justify-content: center; }
  .hero-copy h1 { max-width: 1020px; margin: 0.85rem auto 1rem; font-size: clamp(2.65rem, 6vw, 5.35rem); }
  .hero-copy p { max-width: 860px; margin-inline: auto; color: var(--color-muted); font-size: clamp(1.08rem, 2vw, 1.32rem); }
  .hero-actions { display: flex; flex-wrap: wrap; justify-content: center; gap: 0.75rem; margin-top: 1.4rem; }
  .quick-answer { padding: 1.35rem; background: linear-gradient(145deg, rgba(255, 255, 255, 0.96), rgba(220, 251, 255, 0.72)); }
  .hero-copy .quick-answer { max-width: 760px; margin: 2rem auto 0; }
  .quick-answer p { margin: 1rem 0 0; color: var(--color-primary); font-size: 1.12rem; }
  .section-heading { margin-bottom: 1.5rem; }
  .section-heading h2 { margin-top: 0.8rem; }
  .section-heading p { max-width: 760px; color: var(--color-muted); font-size: 1.1rem; }
  .calculator-layout { display: grid; gap: 1.15rem; align-items: start; }
  .calculator-layout.has-sidebar-ad { grid-template-columns: minmax(0, 1fr) minmax(260px, 0.32fr); }
  .calculator-panel { padding: clamp(1.2rem, 3vw, 2rem); }
  .calculator-form { margin-bottom: 1.25rem; }
  .field-grid { display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 1rem; margin-bottom: 1.25rem; }
  label { display: grid; gap: 0.4rem; color: var(--color-primary); font-weight: 800; }
  label span { font-size: 0.95rem; }
  .label-with-help { display: inline-flex; align-items: center; gap: 0.45rem; width: fit-content; }
  .tooltip { position: relative; display: inline-flex; }
  .tooltip-trigger { display: inline-grid; place-items: center; width: 1.25rem; height: 1.25rem; border: 1px solid var(--color-border-strong); border-radius: 999px; background: #fff; color: var(--color-primary); font: inherit; font-size: 0.78rem; font-weight: 900; cursor: help; }
  .tooltip-trigger:focus { outline: 3px solid rgba(32, 199, 215, 0.2); border-color: var(--color-accent-dark); }
  .tooltip-content { position: absolute; left: 50%; bottom: calc(100% + 0.6rem); z-index: 2; width: min(300px, calc(100vw - 3rem)); transform: translateX(-50%); border: 1px solid var(--color-border); border-radius: var(--radius-md); padding: 0.75rem 0.85rem; background: var(--color-primary); color: #fff; box-shadow: 0 14px 32px rgba(6, 25, 35, 0.18); font-size: 0.88rem; font-weight: 650; line-height: 1.45; opacity: 0; pointer-events: none; transition: opacity 0.15s ease, transform 0.15s ease; }
  .tooltip-content::before { content: ''; position: absolute; left: 0; top: 100%; width: 100%; height: 0.75rem; }
