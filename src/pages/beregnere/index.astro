---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import JsonLd from '../../components/JsonLd.astro';
import { breadcrumbsJsonLd } from '../../lib/structured-data';

const breadcrumbs = [
  { name: 'Forside', url: '/' },
  { name: 'Beregnere', url: '/beregnere/' },
];
---

<BaseLayout
  title="Beregnere til aircondition, varmepumper og indeklima"
  description="Praktiske beregnere til danske hjem. Beregn luftfugtighed, strømforbrug, varmepumpeøkonomi og hvor stor aircondition eller varmepumpe du bør kigge efter."
  path="/beregnere/"
>
  <section class="section container page-head">
    <div>
      <Breadcrumbs items={breadcrumbs} />
      <span class="pill">Beregnere</span>
      <h1>Beregnere til bedre indeklima</h1>
      <p>Brug vores beregnere som et praktisk første estimat, før du vælger aircondition, varmepumpe eller andre løsninger til hjemmet.</p>
    </div>
  </section>

  <section class="container calculators">
    <article class="surface calculator-card">
      <span class="card-kicker">Ny beregner</span>
      <h2><a href="/beregnere/koelebehov-beregner/">Kølebehov beregner til rum</a></h2>
      <p>Beregn kølebehov i kW og BTU/h ud fra m², loftshøjde, solindfald, vinduer, personer og elektronik.</p>
      <a class="button" href="/beregnere/koelebehov-beregner/">Åbn beregner</a>
    </article>

    <article class="surface calculator-card">
      <span class="card-kicker">Ny beregner</span>
      <h2><a href="/beregnere/luftfugtighed-beregner/">Luftfugtighed beregner og indeklima-tjek</a></h2>
      <p>Indtast temperatur, relativ luftfugtighed, rumtype og symptomer, og se om luftfugtigheden er lav, normal eller høj.</p>
      <a class="button" href="/beregnere/luftfugtighed-beregner/">Åbn beregner</a>
    </article>

    <article class="surface calculator-card">
      <span class="card-kicker">Ny beregner</span>
      <h2><a href="/beregnere/affugter-eller-aircondition/">Affugter eller aircondition?</a></h2>
      <p>Indtast problem, temperatur, luftfugtighed, rumtype og sæson, og se om du bør vælge affugter, aircondition, dry mode eller bedre ventilation.</p>
      <a class="button" href="/beregnere/affugter-eller-aircondition/">Åbn beregner</a>
    </article>

    <article class="surface calculator-card">
      <span class="card-kicker">Ny beregner</span>
      <h2><a href="/beregnere/btu-beregner-aircondition/">BTU beregner til aircondition</a></h2>
      <p>Indtast m2, loftshøjde, solindfald, isolering og personer, og få anbefalet BTU, kW og valg mellem mobil og split aircondition.</p>
      <a class="button" href="/beregnere/btu-beregner-aircondition/">Åbn beregner</a>
    </article>

    <article class="surface calculator-card">
      <span class="card-kicker">Ny beregner</span>
      <h2><a href="/beregnere/kan-varmepumpe-betale-sig/">Kan en varmepumpe betale sig?</a></h2>
      <p>Indtast varmekilde, varmeregning, elpris, SCOP og pris inkl. montering, og beregn besparelse, CO2 og tilbagebetalingstid.</p>
      <a class="button" href="/beregnere/kan-varmepumpe-betale-sig/">Åbn beregner</a>
    </article>

    <article class="surface calculator-card">
      <span class="card-kicker">Ny beregner</span>
      <h2><a href="/beregnere/varmepumpe-vs-elradiator/">Varmepumpe vs elradiator</a></h2>
      <p>Indtast antal elradiatorer, årligt elforbrug til varme, elpris, SCOP og installationspris, og beregn besparelse og tilbagebetalingstid.</p>
      <a class="button" href="/beregnere/varmepumpe-vs-elradiator/">Åbn beregner</a>
    </article>

    <article class="surface calculator-card">
      <span class="card-kicker">Vigtig beregner</span>
      <h2><a href="/beregnere/aircondition-varmepumpe-stoerrelse/">Hvor stor aircondition eller varmepumpe skal jeg bruge?</a></h2>
      <p>Indtast rumstørrelse, loftshøjde, isolering, solindfald og vinduer, og få et estimat på anbefalet kapacitet i kW.</p>
      <a class="button" href="/beregnere/aircondition-varmepumpe-stoerrelse/">Åbn beregner</a>
    </article>

    <article class="surface calculator-card">
      <span class="card-kicker">Populær beregner</span>
      <h2><a href="/beregnere/hvad-koster-aircondition-i-stroem/">Hvad koster aircondition i strøm?</a></h2>
      <p>Indtast watt eller kW, timer pr. dag, dage pr. måned og elpris, og få pris pr. dag, pr. måned og pr. sommer.</p>
      <a class="button" href="/beregnere/hvad-koster-aircondition-i-stroem/">Åbn beregner</a>
    </article>
  </section>

  <JsonLd data={breadcrumbsJsonLd(breadcrumbs)} />
</BaseLayout>

<style>
  .page-head { padding-bottom: 2rem; }
  .page-head p { max-width: 760px; color: var(--color-muted); font-size: 1.16rem; }
  .calculators { display: grid; gap: 1.15rem; padding-bottom: clamp(3rem, 7vw, 6rem); }
  .calculator-card { max-width: 780px; padding: clamp(1.25rem, 3vw, 2rem); }
  .calculator-card h2 { margin: 0.8rem 0 0.75rem; font-size: clamp(1.7rem, 3.4vw, 2.5rem); }
  .calculator-card h2 a { color: var(--color-primary); text-decoration: none; }
  .calculator-card p { color: var(--color-muted); font-size: 1.08rem; }
  .card-kicker { width: fit-content; border-radius: 999px; padding: 0.22rem 0.6rem; background: var(--color-warm-soft); color: #8a5200; font-size: 0.76rem; font-weight: 850; letter-spacing: 0.06em; text-transform: uppercase; }
</style>
