---
import { CATEGORIES, SITE } from '../lib/constants';
---

<header class="site-header">
  <div class="container header-inner">
    <a class="brand" href="/" aria-label={`${SITE.name} forside`}>
      <span>{SITE.name}</span>
    </a>
    <nav class="nav" aria-label="Primær navigation">
      {Object.values(CATEGORIES).map((category) => <a href={`/${category.slug}/`}>{category.name}</a>)}
    </nav>
  </div>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 20;
    background: rgba(244, 247, 248, 0.82);
    border-bottom: 1px solid var(--color-border);
    backdrop-filter: blur(16px);
  }

  .header-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.25rem;
    min-height: 82px;
  }

  .brand {
    display: inline-flex;
    align-items: center;
    color: var(--color-primary);
    font-weight: 800;
    text-decoration: none;
    letter-spacing: -0.02em;
    white-space: nowrap;
  }

  .nav {
    display: flex;
    align-items: center;
    justify-content: flex-end;
    gap: 0.35rem;
    font-size: 0.95rem;
    font-weight: 700;
    flex: 1;
  }

  .nav a {
    color: var(--color-primary);
    border-radius: 999px;
    padding: 0.55rem 0.8rem;
    text-decoration: none;
    transition: background 160ms ease, color 160ms ease;
  }

  .nav a:hover {
    background: rgba(32, 199, 215, 0.12);
    color: var(--color-accent-dark);
  }

  @media (max-width: 980px) {
    .header-inner {
      align-items: flex-start;
      flex-direction: column;
      padding-block: 0.85rem;
    }

    .nav {
      width: 100%;
      justify-content: flex-start;
      overflow-x: auto;
      padding-bottom: 0.25rem;
      white-space: nowrap;
    }

  }
</style>
