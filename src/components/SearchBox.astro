---
interface Props {
  compact?: boolean;
}

const { compact = false } = Astro.props;
---

<form class={`search-box${compact ? ' compact' : ''}`} action="/soeg/" role="search">
  <label class="sr-only" for="site-search">Søg på Indeklima Guiden</label>
  <input id="site-search" type="search" name="q" placeholder="Søg efter aircondition, varmepumpe eller indeklima" />
  <button type="submit">Søg</button>
</form>

<style>
  .search-box { display: flex; gap: 0.5rem; width: 100%; }
  input { min-width: 0; flex: 1; border: 1px solid var(--color-border); border-radius: 999px; padding: 0.85rem 1rem; background: rgba(255, 255, 255, 0.86); color: var(--color-text); font: inherit; outline: none; transition: border-color 160ms ease, box-shadow 160ms ease; }
  input:focus { border-color: var(--color-accent); box-shadow: 0 0 0 4px rgba(32, 199, 215, 0.16); }
  button { border: 1px solid var(--color-primary); border-radius: 999px; padding: 0.85rem 1.05rem; background: var(--color-primary); color: #fff; cursor: pointer; font: inherit; font-weight: 800; }
  .compact { max-width: 360px; }
  .compact input { padding-block: 0.62rem; font-size: 0.92rem; }
  .compact button { padding: 0.62rem 0.88rem; font-size: 0.9rem; }
  .sr-only { position: absolute; width: 1px; height: 1px; overflow: hidden; clip: rect(0, 0, 0, 0); white-space: nowrap; }

  @media (max-width: 980px) {
    .compact { max-width: none; }
  }
</style>
