---
interface Props {
  pros?: string[];
  cons?: string[];
}
const { pros = [], cons = [] } = Astro.props;
---

<div class="pros-cons">
  <section>
    <h3>Fordele</h3>
    <ul>{pros.map((item) => <li>{item}</li>)}</ul>
  </section>
  <section>
    <h3>Ulemper</h3>
    <ul>{cons.map((item) => <li>{item}</li>)}</ul>
  </section>
</div>

<style>
  .pros-cons { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; margin: 2rem 0; }
  section { border: 1px solid var(--color-border); border-radius: var(--radius-md); padding: 1rem; background: var(--color-surface); }
  h3 { margin-top: 0; }
  li { margin: 0.45rem 0; }
  @media (max-width: 680px) { .pros-cons { grid-template-columns: 1fr; } }
</style>
