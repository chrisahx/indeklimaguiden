---
import { CATEGORIES, SITE } from '../lib/constants';
---

<footer class="site-footer">
  <div class="container footer-grid">
    <div>
      <a class="footer-brand" href="/">
        <img src="/logo.svg" alt="" width="54" height="37" loading="lazy" />
        <span>{SITE.name}</span>
      </a>
      <p>Uafhængig, praktisk vejledning om aircondition, varmepumper og indeklima til danske boligejere.</p>
      <p><a href={`mailto:${SITE.contactEmail}`}>{SITE.contactEmail}</a></p>
    </div>
    <nav aria-label="Kategorier">
      <h2>Kategorier</h2>
      {Object.values(CATEGORIES).map((category) => <a href={`/${category.slug}/`}>{category.name}</a>)}
      <a href="/beregnere/">Beregnere</a>
    </nav>
    <nav aria-label="Information">
      <h2>Information</h2>
      <a href="/om-os/">Om os</a>
      <a href="/kontakt/">Kontakt</a>
      <a href="/redaktionelle-retningslinjer/">Redaktionelle retningslinjer</a>
      <a href="/annoncering-og-affiliate/">Annoncering og affiliate</a>
      <a href="/privatlivspolitik/">Privatlivspolitik</a>
      <a href="/cookiepolitik/">Cookiepolitik</a>
    </nav>
  </div>
</footer>

<style>
  .site-footer {
    margin-top: 4rem;
    padding: 3rem 0;
    background:
      radial-gradient(circle at 16% 20%, rgba(7, 155, 211, 0.24), transparent 18rem),
      radial-gradient(circle at 84% 18%, rgba(112, 182, 44, 0.2), transparent 17rem),
      linear-gradient(135deg, var(--color-primary), #06263f 72%);
    color: #eaf1ff;
  }

  .footer-grid {
    display: grid;
    grid-template-columns: 1.4fr 1fr 1fr;
    gap: 2rem;
  }

  .footer-brand {
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
    margin-bottom: 0.8rem;
    color: #fff;
    font-size: 1.2rem;
    font-weight: 800;
    text-decoration: none;
  }

  .footer-brand img {
    width: 3.4rem;
    height: auto;
  }

  .site-footer h2 {
    margin: 0 0 0.8rem;
    color: #fff;
    font-size: 0.9rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  .site-footer a,
  .site-footer button {
    display: block;
    margin: 0.35rem 0;
    border: 0;
    padding: 0;
    background: transparent;
    color: #eaf1ff;
    cursor: pointer;
    font: inherit;
    text-align: left;
  }

  @media (max-width: 760px) {
    .footer-grid { grid-template-columns: 1fr; }
  }
</style>
