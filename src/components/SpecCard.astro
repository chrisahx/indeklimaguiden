---
interface Props { label: string; value: string; note?: string }
const { label, value, note } = Astro.props;
---

<article class="spec-card">
  <span>{label}</span>
  <strong>{value}</strong>
  {note && <p>{note}</p>}
</article>

<style>
  .spec-card { border: 1px solid var(--color-border); border-radius: var(--radius-md); padding: 1rem; background: var(--color-surface); }
  span { display: block; color: var(--color-muted); font-size: 0.8rem; font-weight: 800; letter-spacing: 0.05em; text-transform: uppercase; }
  strong { display: block; margin-top: 0.35rem; color: var(--color-primary); font-size: 1.4rem; }
  p { margin: 0.35rem 0 0; color: var(--color-muted); font-size: 0.95rem; }
</style>
